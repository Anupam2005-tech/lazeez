generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String         @id @default(uuid()) @db.Uuid
  firebaseUid    String         @unique
  email          String?
  phone          String?
  name           String?
  password       String?
  role           String         @default("customer")
  flatNo         String?
  landmark       String?
  pincode        String?
  address        String?
  lat            Float?
  lng            Float?
  createdAt      DateTime       @default(now())
  feedbacks      Feedback[]
  orders         Order[]
  savedAddresses SavedAddress[]
}

model Category {
  id        String     @id @default(uuid()) @db.Uuid
  name      String     @unique
  image     String?
  menuItems MenuItem[]
}

model MenuItem {
  id           String      @id @default(uuid()) @db.Uuid
  uid          String      @unique
  name         String
  description  String?
  price        Float
  image        String?
  available    Boolean     @default(true)
  isVeg        Boolean     @default(true)
  isBestSeller Boolean     @default(false)
  categoryId   String      @db.Uuid
  createdAt    DateTime    @default(now())
  category     Category    @relation(fields: [categoryId], references: [id])
  orderItems   OrderItem[]
}

model Order {
  id               String      @id @default(uuid()) @db.Uuid
  userId           String      @db.Uuid
  status           String      @default("Pending")
  itemTotal        Float       @default(0)
  deliveryFee      Float       @default(0)
  platformFee      Float       @default(0)
  totalAmount      Float
  paymentMethod    String      @default("Online")
  paymentStatus    String      @default("Pending")
  paymentTimestamp DateTime?
  address          String?
  customerName     String?
  customerPhone    String?
  suggestions      String?
  dineIn           Boolean     @default(false)
  cancelReason     String?
  refundStatus     String?
  createdAt        DateTime    @default(now())
  feedback         Feedback[]
  user             User        @relation(fields: [userId], references: [id])
  items            OrderItem[]
}

model OrderItem {
  id         String   @id @default(uuid()) @db.Uuid
  orderId    String   @db.Uuid
  menuItemId String   @db.Uuid
  quantity   Int
  unitPrice  Float
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  order      Order    @relation(fields: [orderId], references: [id])
}

model Feedback {
  id          String   @id @default(uuid()) @db.Uuid
  orderId     String   @db.Uuid
  userId      String   @db.Uuid
  foodRating  Int
  storeRating Int
  comment     String?
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@unique([orderId, userId])
}

model Offer {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  image       String?
  dishName    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Setting {
  id    String @id @default(uuid()) @db.Uuid
  key   String @unique
  value String
}

model SavedAddress {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  label     String
  flatNo    String?
  address   String
  landmark  String?
  pincode   String?
  lat       Float?
  lng       Float?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
