<%- include('../partials/header') %>

<div class="min-h-[80vh] flex flex-col items-center justify-center bg-white px-4">
  
  <a href="/" class="flex items-center gap-2 text-sm font-semibold text-[#686b78] hover:text-orange-500 transition-colors mb-10 group self-start sm:self-center max-w-[400px] w-full">
    <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to Home
  </a>
  
  <div class="max-w-[400px] w-full">
    
    <div class="flex justify-between items-start mb-8">
      <div>
        <h2 class="text-3xl font-bold text-[#282c3f] tracking-tight">Login</h2>
        <p class="text-[14px] text-[#282c3f] mt-2">
          or <a href="/auth/register" class="text-orange-500 font-medium">create an account</a>
        </p>
        <div class="w-8 h-[2px] bg-[#282c3f] mt-4"></div>
      </div>
      <div class="w-16 h-auto flex items-center justify-center">
        <img src="/img/logo.svg" alt="Lazeez" class="w-full h-auto">
      </div>
    </div>

    <div id="error-msg" class="hidden mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-600"></div>

    <form id="loginForm" class="space-y-0">
      <div class="relative border border-[#d4d5d9] rounded-none border-b-0 focus-within:border-black focus-within:z-10 bg-white">
        <label class="absolute text-[12px] font-medium text-[#93959f] top-1 left-4">Email</label>
        <input type="email" id="email" required class="w-full h-16 pt-5 px-4 outline-none text-[#282c3f] text-[15px] font-medium bg-transparent">
      </div>
      
      <div class="relative border border-[#d4d5d9] rounded-none focus-within:border-black focus-within:z-10 bg-white">
        <label class="absolute text-[12px] font-medium text-[#93959f] top-1 left-4">Password</label>
        <input type="password" id="password" required class="w-full h-16 pt-5 px-4 outline-none text-[#282c3f] text-[15px] tracking-wider font-medium bg-transparent">
      </div>

      <button type="submit" id="loginBtn" class="w-full bg-[#fc8019] text-white py-4 font-bold text-[14px] uppercase tracking-wider mb-4 hover:shadow-md transition-shadow">
        Login
      </button>
    </form>

    <div class="text-[11px] text-[#686b78] mt-2 leading-relaxed">
      By clicking on Login, I accept the 
      <a href="#" class="font-bold text-[#282c3f]">Terms & Conditions</a> & 
      <a href="#" class="font-bold text-[#282c3f]">Privacy Policy</a>
    </div>

    <div class="mt-8 pt-8 border-t border-[#e9e9eb]">
      <p class="text-[13px] text-center text-[#93959f] mb-4">Or alternative login</p>
      <div class="grid grid-cols-2 gap-4">
        <button onclick="tryGoogleLogin()" class="flex items-center justify-center gap-2 w-full py-3 border border-[#d4d5d9] hover:bg-gray-50 transition-colors text-sm font-bold text-[#3d4152] uppercase">
          Google
        </button>
        <button onclick="tryPhoneLogin()" class="flex items-center justify-center gap-2 w-full py-3 border border-[#d4d5d9] hover:bg-gray-50 transition-colors text-sm font-bold text-[#3d4152] uppercase">
          Phone
        </button>
      </div>
    </div>

    <div class="mt-4 p-3 bg-gray-50 rounded-lg">
      <p class="text-[11px] text-[#93959f] text-center">Don't have an account? <a href="/auth/register" class="text-orange-500 font-semibold">Sign up</a></p>
    </div>
    
  </div>
</div>

<script>
  function showError(msg) {
    var el = document.getElementById('error-msg');
    el.textContent = msg;
    el.classList.remove('hidden');
  }
  function hideError() {
    document.getElementById('error-msg').classList.add('hidden');
  }

  function tryGoogleLogin() {
    if (window.RestoAuth && window.RestoAuth.handleGoogleLogin) {
      RestoAuth.handleGoogleLogin();
    } else {
      showError('Google login is not available. Use email/password login.');
    }
  }

  function tryPhoneLogin() {
    if (window.RestoAuth && window.RestoAuth.showOtpModal) {
      RestoAuth.showOtpModal();
    } else {
      showError('Phone login is not available. Use email/password login.');
    }
  }

  document.getElementById('loginForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    hideError();
    var btn = document.getElementById('loginBtn');
    var email = document.getElementById('email').value;
    var password = document.getElementById('password').value;
    btn.disabled = true;
    btn.classList.add('btn-loading');

    // Try Firebase auth first, fall back to local auth
    try {
      if (window.RestoAuth && window.RestoAuth.handleEmailLogin) {
        var recaptchaToken = '';
        if (window.grecaptcha && window.RECAPTCHA_SITE_KEY) {
          try { recaptchaToken = await grecaptcha.execute(window.RECAPTCHA_SITE_KEY, {action: 'login'}); } catch(e) {}
        }
        // Attempt Firebase login
        var auth = firebase.auth();
        var cred = await auth.signInWithEmailAndPassword(email, password);
        var idToken = await cred.user.getIdToken();
        var res = await fetch('/auth/verify-token', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ idToken: idToken, recaptchaToken: recaptchaToken })
        });
        var data = await res.json();
        if (data.success) {
          window.location.href = '/';
          return;
        }
        showError(data.error || 'Login failed');
      } else {
        throw new Error('Firebase not available');
      }
    } catch (firebaseErr) {
      // Firebase failed, try local auth
      try {
        var res = await fetch('/auth/local-login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email, password: password })
        });
        var data = await res.json();
        if (data.success) {
          window.location.href = '/';
          return;
        }
        showError(data.error || 'Login failed');
      } catch (localErr) {
        showError('Login failed. Please check your credentials.');
      }
    }
    btn.disabled = false;
    btn.classList.remove('btn-loading');
  });
</script>

<%- include('../partials/footer') %>
