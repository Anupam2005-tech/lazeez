<!-- Admin Sidebar Component -->
<aside class="w-64 bg-[#1b1e24] text-gray-300 flex-shrink-0 flex flex-col h-full border-r border-gray-800 fixed inset-y-0 left-0 z-20 md:relative transform transition-transform duration-300 ease-in-out"
       :class="sidebarOpen ? 'translate-x-0' : '-translate-x-full md:translate-x-0'">
  <div class="h-16 flex items-center justify-between px-6 border-b border-gray-700 bg-[#1b1e24] flex-shrink-0">
    <a href="/admin/dashboard" class="flex items-center gap-2">
      <svg class="w-7 h-7 text-orange-500" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
      </svg>
      <span class="text-white text-lg font-bold tracking-tight">Lazeez Admin</span>
    </a>
    <button @click="sidebarOpen = false" class="md:hidden text-gray-400 hover:text-white focus:outline-none">
      <span class="sr-only">Close sidebar</span>
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <div class="py-4 flex-1 overflow-y-auto">
    <nav class="space-y-1 px-3">
      <a href="/admin/dashboard?tab=overview" class="group flex items-center px-3 py-2.5 text-sm font-medium rounded-lg hover:bg-gray-800 hover:text-white transition-colors" :class="(!window.location.search.includes('tab=') || window.location.search.includes('tab=overview')) ? 'bg-orange-500/10 text-orange-400' : ''">
        <svg class="text-gray-400 group-hover:text-orange-400 flex-shrink-0 -ml-1 mr-3 h-5 w-5" :class="(!window.location.search.includes('tab=') || window.location.search.includes('tab=overview')) ? 'text-orange-400' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
        </svg>
        Dashboard
      </a>

      <a href="/admin/dashboard?tab=orders" class="group flex items-center px-3 py-2.5 text-sm font-medium rounded-lg hover:bg-gray-800 hover:text-white transition-colors" :class="window.location.search.includes('tab=orders') ? 'bg-orange-500/10 text-orange-400' : ''">
        <svg class="text-gray-400 group-hover:text-orange-400 flex-shrink-0 -ml-1 mr-3 h-5 w-5" :class="window.location.search.includes('tab=orders') ? 'text-orange-400' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
        </svg>
        Orders
      </a>

      <a href="/admin/refunds" class="group flex items-center px-3 py-2.5 text-sm font-medium rounded-lg hover:bg-gray-800 hover:text-white transition-colors" :class="window.location.pathname.includes('/admin/refunds') ? 'bg-orange-500/10 text-orange-400' : ''">
        <svg class="text-gray-400 group-hover:text-orange-400 flex-shrink-0 -ml-1 mr-3 h-5 w-5" :class="window.location.pathname.includes('/admin/refunds') ? 'text-orange-400' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Refunds
      </a>

      <a href="/admin/dashboard?tab=menu" class="group flex items-center px-3 py-2.5 text-sm font-medium rounded-lg hover:bg-gray-800 hover:text-white transition-colors" :class="window.location.search.includes('tab=menu') ? 'bg-orange-500/10 text-orange-400' : ''">
        <svg class="text-gray-400 group-hover:text-orange-400 flex-shrink-0 -ml-1 mr-3 h-5 w-5" :class="window.location.search.includes('tab=menu') ? 'text-orange-400' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
        </svg>
        Menu Management
      </a>

      <a href="/admin/categories" class="group flex items-center px-3 py-2.5 text-sm font-medium rounded-lg hover:bg-gray-800 hover:text-white transition-colors" :class="window.location.pathname.includes('/admin/categories') ? 'bg-orange-500/10 text-orange-400' : ''">
        <svg class="text-gray-400 group-hover:text-orange-400 flex-shrink-0 -ml-1 mr-3 h-5 w-5" :class="window.location.pathname.includes('/admin/categories') ? 'text-orange-400' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
        </svg>
        Categories
      </a>

      <a href="/admin/dashboard?tab=offers" class="group flex items-center px-3 py-2.5 text-sm font-medium rounded-lg hover:bg-gray-800 hover:text-white transition-colors" :class="window.location.search.includes('tab=offers') ? 'bg-orange-500/10 text-orange-400' : ''">
        <svg class="text-gray-400 group-hover:text-orange-400 flex-shrink-0 -ml-1 mr-3 h-5 w-5" :class="window.location.search.includes('tab=offers') ? 'text-orange-400' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7" />
        </svg>
        Offers
      </a>

      <a href="/admin/dashboard?tab=reports" class="group flex items-center px-3 py-2.5 text-sm font-medium rounded-lg hover:bg-gray-800 hover:text-white transition-colors" :class="window.location.search.includes('tab=reports') ? 'bg-orange-500/10 text-orange-400' : ''">
        <svg class="text-gray-400 group-hover:text-orange-400 flex-shrink-0 -ml-1 mr-3 h-5 w-5" :class="window.location.search.includes('tab=reports') ? 'text-orange-400' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
        </svg>
        Reports
      </a>

      <a href="/admin/dashboard?tab=overview" onclick="setTimeout(function(){document.getElementById('setting-delivery-rate')?.scrollIntoView({behavior:'smooth'})}, 500)" class="group flex items-center px-3 py-2.5 text-sm font-medium rounded-lg hover:bg-gray-800 hover:text-white transition-colors">
        <svg class="text-gray-400 group-hover:text-orange-400 flex-shrink-0 -ml-1 mr-3 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        Settings
      </a>

      <div class="border-t border-gray-700 my-3 pt-3">
        <a href="/" target="_blank" class="group flex items-center px-3 py-2.5 text-sm font-medium rounded-lg hover:bg-gray-800 hover:text-white transition-colors">
          <svg class="text-gray-400 group-hover:text-orange-400 flex-shrink-0 -ml-1 mr-3 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          View Storefront
        </a>
      </div>
    </nav>
  </div>
  
  <div class="p-4 border-t border-gray-700 flex-shrink-0" x-data="{ userMenuOpen: false }">
    <div class="flex items-center gap-3 cursor-pointer select-none" @click="userMenuOpen = !userMenuOpen">
      <div class="w-8 h-8 rounded-full bg-orange-500 flex items-center justify-center flex-shrink-0">
        <span class="text-white text-xs font-bold"><%= (user ? (user.name || user.email || 'A') : 'A').charAt(0).toUpperCase() %></span>
      </div>
      <div class="min-w-0 flex-1">
        <div class="text-sm font-semibold text-white truncate"><%= user ? user.name || 'Admin' : 'Admin' %></div>
        <div class="text-xs text-gray-500 truncate"><%= user ? user.email || user.phone || '' : '' %></div>
      </div>
      <svg class="w-4 h-4 text-gray-500 transition-transform" :class="userMenuOpen ? 'rotate-180' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>

    <div x-show="userMenuOpen" x-cloak @click.away="userMenuOpen = false" class="mt-2 bg-gray-800 rounded-lg overflow-hidden shadow-lg border border-gray-700">
      <button onclick="RestoAuth.handleLogout('/admin/logout', '/admin/login')" class="w-full text-left flex items-center gap-2 px-4 py-2.5 text-sm text-gray-300 hover:bg-gray-700 hover:text-white transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
        </svg>
        Logout
      </button>
      <a href="/admin/login" class="w-full text-left flex items-center gap-2 px-4 py-2.5 text-sm text-gray-300 hover:bg-gray-700 hover:text-white transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
        </svg>
        Switch Account
      </a>
    </div>
  </div>
</aside>
