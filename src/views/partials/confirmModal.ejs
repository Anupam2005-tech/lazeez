<!-- Global Confirm Modal -->
<div id="global-confirm-modal" x-data="{ show: false, title: '', message: '', confirmText: 'Confirm', danger: true, resolve: null }" 
     x-show="show" x-cloak
     x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
     x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
     class="fixed inset-0 z-[99998] flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" @click="show=false; if(resolve) resolve(false)"></div>
  <div x-show="show" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 scale-95" x-transition:enter-end="opacity-100 scale-100"
       x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100 scale-100" x-transition:leave-end="opacity-0 scale-95"
       class="relative bg-white rounded-2xl shadow-2xl max-w-sm w-full mx-auto overflow-hidden" @click.stop>
    <div class="p-6 text-center">
      <div class="mx-auto w-14 h-14 rounded-full flex items-center justify-center mb-4" :class="danger ? 'bg-red-100' : 'bg-orange-100'">
        <svg class="w-7 h-7" :class="danger ? 'text-red-600' : 'text-orange-600'" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
        </svg>
      </div>
      <h3 class="text-lg font-bold text-gray-900 mb-2" x-text="title"></h3>
      <p class="text-sm text-gray-500 mb-6" x-text="message"></p>
      <div class="flex gap-3 justify-center">
        <button @click="show=false; if(resolve) resolve(false)" 
                class="px-5 py-2.5 rounded-xl text-sm font-semibold bg-gray-100 hover:bg-gray-200 text-gray-700 transition-colors">
          Cancel
        </button>
        <button @click="show=false; if(resolve) resolve(true)" 
                class="px-5 py-2.5 rounded-xl text-sm font-semibold text-white transition-colors"
                :class="danger ? 'bg-red-600 hover:bg-red-700' : 'bg-orange-500 hover:bg-orange-600'">
          <span x-text="confirmText"></span>
        </button>
      </div>
    </div>
  </div>
</div>
<script>
  (function() {
    var modal = document.getElementById('global-confirm-modal');
    if (!modal || !modal.__x) {
      // Alpine may not have initialized yet, defer
      document.addEventListener('alpine:init', setupConfirm);
    } else {
      setupConfirm();
    }
    function setupConfirm() {
      window.RestoConfirm = {
        show: function(opts) {
          return new Promise(function(resolve) {
            var el = document.getElementById('global-confirm-modal');
            var data = el._x_dataStack[0];
            data.title = opts.title || 'Are you sure?';
            data.message = opts.message || 'This action cannot be undone.';
            data.confirmText = opts.confirmText || 'Confirm';
            data.danger = opts.danger !== false;
            data.resolve = resolve;
            data.show = true;
          });
        },
        handleDelete: function(form, evt, message, title) {
          evt.preventDefault();
          this.show({ title: title || 'Confirm Delete', message: message || 'This action cannot be undone.', confirmText: 'Delete' }).then(function(ok) {
            if (ok) form.submit();
          });
          return false;
        },
        handleAction: function(evt, message, callback, title) {
          evt.preventDefault();
          this.show({ title: title || 'Are you sure?', message: message || 'This action cannot be undone.' }).then(function(ok) {
            if (ok) callback();
          });
        }
      };
    }
  })();
</script>
