<!-- Swiggy Fixed White Navbar -->
<nav class="fixed top-0 left-0 w-full z-50 bg-white swiggy-nav-shadow transition-all duration-300 pointer-events-auto h-14 sm:h-20 flex items-center">
  <div class="max-w-[1200px] w-full mx-auto px-3 sm:px-6 flex justify-between items-center h-full">
    
    <!-- Brand / Location Block -->
    <div class="flex items-center gap-4 sm:gap-6 h-full shrink-0">
      <a href="/" class="flex items-center shrink-0">
        <img src="/img/logo.svg" alt="Lazeez" class="h-8 sm:h-12 w-auto">
      </a>

      <!-- Location snippet -->
      <div class="flex items-center gap-1 sm:gap-2 group cursor-pointer pr-2 sm:pr-4 border-r-2 border-transparent hover:text-orange-500 transition-colors relative" 
           x-data="{ locOpen: false }" @click.away="locOpen = false">
        <div @click="locOpen = !locOpen" class="flex items-center gap-1 sm:gap-2">
          <svg class="w-4 h-4 text-orange-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <span id="navbar-location" class="text-xs sm:text-sm font-normal text-gray-500 line-clamp-1 max-w-[80px] sm:max-w-[180px]">Detecting...</span>
          <svg class="w-3 h-3 sm:w-4 sm:h-4 text-orange-500 cursor-pointer shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </div>
        <!-- Location Dropdown -->
        <div x-show="locOpen" x-transition.opacity x-cloak class="absolute top-[70px] left-0 w-[min(320px,calc(100vw-2rem))] bg-white border border-gray-100 shadow-2xl rounded-xl overflow-hidden z-50 p-4">
          <!-- GPS Detect Button -->
          <button id="gps-detect-btn" @click="locOpen = false" class="w-full flex items-center gap-3 p-3 rounded-lg bg-orange-50 hover:bg-orange-100 transition-colors mb-3 cursor-pointer border-none">
            <div class="w-10 h-10 rounded-full bg-[#fc8019] flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div class="text-left">
              <p class="text-sm font-bold text-[#3d4152]">Detect my location</p>
              <p class="text-xs text-gray-500">Using GPS</p>
            </div>
          </button>
          <div class="flex items-center gap-2 mb-3">
            <div class="flex-1 h-px bg-gray-200"></div>
            <span class="text-[11px] text-gray-400 font-medium uppercase">or</span>
            <div class="flex-1 h-px bg-gray-200"></div>
          </div>
          <!-- Search Bar -->
          <div class="relative">
            <svg class="w-4 h-4 text-gray-400 absolute left-3 top-1/2 -translate-y-1/2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            <input id="location-search-input" type="text" placeholder="Search area..." class="w-full border border-gray-200 rounded-lg pl-9 pr-3 py-2.5 text-sm outline-none focus:border-[#fc8019] transition-colors" autocomplete="off">
          </div>
          <!-- Search Results -->
          <div id="location-search-results" class="mt-2 max-h-[200px] overflow-y-auto hidden">
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile Search Icon (sm:hidden) -->
    <button id="mobile-search-trigger" class="sm:hidden flex items-center px-2 text-[#3d4152] bg-transparent border-none cursor-pointer">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
    </button>

    <!-- Right Menu Links -->
    <div class="flex items-center h-full sm:gap-6 gap-1">
      
      <!-- Search Button (desktop only - opens modal) -->
      <button id="search-trigger-btn" class="hidden sm:flex items-center gap-2 h-full px-2 text-[15px] font-semibold text-[#3d4152] hover:text-orange-500 transition-colors bg-transparent border-none cursor-pointer">
        <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentcolor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <span>Search</span>
      </button>

      <!-- Offers -->
      <a href="/offers" class="flex items-center gap-2 h-full px-2 text-[15px] font-semibold text-[#3d4152] hover:text-orange-500 transition-colors">
        <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
        <div class="relative hidden sm:block">
          <span>Offers</span>
          <% if (typeof unseenOfferCount !== 'undefined' && unseenOfferCount > 0) { %>
            <span id="offer-badge" class="absolute -top-3 -right-5 bg-orange-500 text-white rounded-full min-w-[18px] h-[18px] flex items-center justify-center text-[10px] font-bold px-1"><%= unseenOfferCount %></span>
          <% } else { %>
            <span id="offer-badge" class="absolute -top-3 -right-5 bg-orange-500 text-white rounded-full min-w-[18px] h-[18px] flex items-center justify-center text-[10px] font-bold px-1 hidden">0</span>
          <% } %>
        </div>
      </a>

      <!-- User / Sign In -->
      <% if (user) { %>
        <div class="relative group h-full flex items-center px-2 cursor-pointer" x-data="{ open: false }" @click.away="open = false" @mouseover="open = true" @mouseleave="open = false">
          <div class="flex items-center gap-2 text-[15px] font-semibold text-[#3d4152] hover:text-orange-500 transition-colors">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            <span class="hidden md:block truncate max-w-[100px]"><%= user.name || 'Profile' %></span>
          </div>
          <!-- Dropdown -->
          <div x-show="open" x-transition.opacity x-cloak class="absolute top-[70px] right-0 w-52 bg-white border border-gray-100 shadow-xl overflow-hidden py-1 z-50">
            <button onclick="openProfileModal()" class="w-full text-left block px-6 py-3 text-[14px] text-gray-700 hover:text-orange-500 hover:bg-gray-50 font-medium">Edit Profile</button>
            <button onclick="openAddressModal()" class="w-full text-left block px-6 py-3 text-[14px] text-gray-700 hover:text-orange-500 hover:bg-gray-50 font-medium">Manage Addresses</button>
            <a href="/orders" class="block px-6 py-3 text-[14px] text-gray-700 hover:text-orange-500 hover:bg-gray-50 font-medium border-t border-gray-100">Orders</a>
            <button onclick="RestoAuth.handleLogout()" class="w-full text-left block px-6 py-3 text-[14px] text-gray-700 hover:text-orange-500 hover:bg-gray-50 font-medium border-t border-gray-100">Logout</button>
          </div>
        </div>
      <% } else { %>
        <a href="/auth/login" class="flex items-center gap-2 h-full px-2 text-[15px] font-semibold text-[#3d4152] hover:text-orange-500 transition-colors">
          <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          <span class="hidden sm:block">Sign In</span>
        </a>
      <% } %>

      <!-- Cart -->
      <a href="/cart" class="flex items-center gap-2 h-full px-2 text-[15px] font-semibold text-[#3d4152] hover:text-orange-500 transition-colors">
        <div class="relative">
          <svg class="w-6 h-6 flex-shrink-0 <%= cart && cart.length > 0 ? 'text-[#60b246]' : '' %>" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
          <span id="navbar-cart-badge" class="absolute -top-1 -right-2 bg-orange-500 text-white rounded-sm px-[5px] text-[10px] font-bold <%= cart && cart.length > 0 ? '' : 'hidden' %>">
            <%= cart ? cart.length : 0 %>
          </span>
        </div>
        <span class="hidden md:block">Cart</span>
      </a>

    </div>
  </div>
</nav>

<!-- Search Modal Overlay -->
<div id="search-modal" class="fixed inset-0 z-[100] hidden">
  <!-- Backdrop -->
  <div id="search-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
  
  <!-- Modal Content -->
  <div class="relative z-10 flex justify-center pt-20 px-4">
    <div class="bg-white w-full max-w-[900px] rounded-2xl shadow-2xl overflow-hidden" style="animation: searchSlideIn 0.25s ease-out;">
      
      <!-- Search Input -->
      <div class="flex items-center gap-3 px-6 py-5 border-b border-gray-100">
        <svg class="w-6 h-6 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input id="search-input" type="text" placeholder="Search for dishes, categories..." class="flex-1 text-lg font-medium text-[#3d4152] outline-none bg-transparent placeholder-gray-400" autocomplete="off">
        <button id="search-close-btn" class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center hover:bg-gray-200 transition-colors flex-shrink-0">
          <svg class="w-4 h-4 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>

      <!-- Results Area -->
      <div id="search-results" class="max-h-[60vh] overflow-y-auto">
        <!-- Default state -->
        <div id="search-empty-state" class="py-10 text-center">
          <svg class="w-16 h-16 mx-auto text-gray-200 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          <p class="text-gray-400 font-medium text-sm">Search for your favourite dishes</p>
        </div>
        <!-- Loading state -->
        <div id="search-loading-state" class="py-10 text-center hidden">
          <div style="display:flex;align-items:center;justify-content:center;gap:8px;">
            <svg style="width:20px;height:20px;animation:resto-spin 0.8s linear infinite;stroke:rgba(107,114,128,1);" viewBox="0 0 256 256">
              <line x1="128" y1="32" x2="128" y2="64" stroke-linecap="round" stroke-width="24"></line>
              <line x1="195.9" y1="60.1" x2="173.3" y2="82.7" stroke-linecap="round" stroke-width="24"></line>
              <line x1="224" y1="128" x2="192" y2="128" stroke-linecap="round" stroke-width="24"></line>
              <line x1="195.9" y1="195.9" x2="173.3" y2="173.3" stroke-linecap="round" stroke-width="24"></line>
            </svg>
            <span style="font-size:13px;font-weight:500;color:rgba(107,114,128,1);">Searching...</span>
          </div>
        </div>
        <!-- Items will be rendered here -->
        <div id="search-items-list"></div>
      </div>
    </div>
  </div>
</div>

<!-- Mobile Full-Page Search Modal -->
<div id="mobile-full-search" class="fixed inset-0 z-[200] bg-white hidden">
  <!-- Search Header -->
  <div class="sticky top-0 z-10 bg-white">
    <div class="flex items-center gap-3 px-4 py-3">
      <button id="mobile-full-search-back" class="w-9 h-9 flex items-center justify-center shrink-0 bg-transparent border-none cursor-pointer">
        <svg class="w-5 h-5 text-[#686b78]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
      </button>
      <div class="flex-1 relative">
        <div class="flex items-center bg-[#f0f0f5] rounded-xl px-4 py-2.5 transition-all duration-200 focus-within:bg-white focus-within:shadow-[0_0_0_2px_#fc801933,0_2px_8px_rgba(252,128,25,0.12)]">
          <svg class="w-[18px] h-[18px] text-[#93959f] shrink-0 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          <input id="mobile-full-search-input" type="text" placeholder="Search for dishes..." class="flex-1 bg-transparent text-[15px] font-medium text-[#282c3f] outline-none placeholder-[#93959f]" autocomplete="off">
          <button id="mobile-full-search-clear" class="hidden ml-2 w-5 h-5 rounded-full bg-[#c0c2c9] flex items-center justify-center shrink-0 border-none cursor-pointer">
            <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
      </div>
    </div>
    <div class="h-px bg-[#e9e9eb]"></div>
  </div>
  <!-- Results -->
  <div class="overflow-y-auto" style="height: calc(100vh - 60px);">
    <div id="mobile-full-search-default" class="py-12 text-center">
      <svg class="w-14 h-14 mx-auto text-[#e9e9eb] mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      <p class="text-[#93959f] font-medium text-sm">Search for your favourite dishes</p>
      <p class="text-[#c0c2c9] text-xs mt-1">Try searching for a dish name or category</p>
    </div>
    <div id="mobile-full-search-loading" class="py-12 text-center hidden">
      <div class="inline-flex items-center gap-2 text-[#93959f]">
        <svg class="w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4m0 12v4m-7.07-3.93l2.83-2.83m8.48-8.48l2.83-2.83M2 12h4m12 0h4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83"/></svg>
        <span class="text-sm font-medium">Searching...</span>
      </div>
    </div>
    <div id="mobile-full-search-empty" class="py-12 text-center hidden">
      <svg class="w-12 h-12 mx-auto text-[#e9e9eb] mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p class="text-[#7e808c] text-sm font-medium">No dishes found</p>
      <p class="text-[#c0c2c9] text-xs mt-1">Try a different search term</p>
    </div>
    <div id="mobile-full-search-list" class="px-3"></div>
  </div>
</div>

<style>
  @keyframes searchSlideIn {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<!-- Edit Profile Modal -->
<div id="profile-modal" class="fixed inset-0 z-[200] hidden">
  <div id="profile-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
  <div class="relative z-10 flex justify-center items-start pt-8 px-4 overflow-y-auto max-h-[95vh]">
    <div class="bg-white w-full max-w-[480px] rounded-2xl shadow-2xl overflow-hidden" style="animation: profileSlideIn 0.25s ease-out;">
      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
        <h2 class="text-lg font-bold text-[#282c3f]">Edit Profile</h2>
        <button id="profile-close-btn" class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center hover:bg-gray-200 transition-colors">
          <svg class="w-4 h-4 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="p-6">
        <form id="profileForm" onsubmit="return false;">
          <div class="mb-4">
            <label class="block text-[12px] font-semibold text-[#93959f] uppercase tracking-wider mb-1">Full Name <span class="text-red-500">*</span></label>
            <input type="text" id="profile-name" required maxlength="100" pattern=".{2,}" title="Name must be at least 2 characters" class="w-full border border-[#d4d5d9] rounded-lg px-4 py-3 text-[14px] text-[#282c3f] outline-none focus:border-[#fc8019] transition-colors" placeholder="Your full name">
          </div>
          <div class="mb-4">
            <label class="block text-[12px] font-semibold text-[#93959f] uppercase tracking-wider mb-1">Phone Number <span class="text-red-500">*</span></label>
            <input type="tel" id="profile-phone" required maxlength="15" pattern="[0-9]{10,15}" title="Enter a valid phone number (10-15 digits)" class="w-full border border-[#d4d5d9] rounded-lg px-4 py-3 text-[14px] text-[#282c3f] outline-none focus:border-[#fc8019] transition-colors" placeholder="Phone number">
          </div>
          <div class="mb-4">
            <label class="block text-[12px] font-semibold text-[#93959f] uppercase tracking-wider mb-1">Email <span class="text-red-500">*</span></label>
            <input type="email" id="profile-email" required class="w-full border border-[#d4d5d9] rounded-lg px-4 py-3 text-[14px] text-[#282c3f] outline-none focus:border-[#fc8019] transition-colors disabled:bg-gray-100 disabled:text-gray-500 disabled:cursor-not-allowed" placeholder="Email address">
            <p id="profile-email-lock-hint" class="hidden text-[11px] text-[#93959f] mt-1">Email cannot be changed once set</p>
          </div>
          <button type="button" onclick="saveProfile()" id="profile-save-btn" class="w-full bg-[#fc8019] text-white py-3.5 font-bold text-[14px] uppercase tracking-wider rounded-lg hover:shadow-lg hover:bg-orange-600 transition-all">
            Save Changes
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Manage Addresses Modal -->
<div id="address-modal" class="fixed inset-0 z-[200] hidden">
  <div id="address-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
  <div class="relative z-10 flex justify-center items-start pt-8 px-4 overflow-y-auto max-h-[95vh]">
    <div class="bg-white w-full max-w-[520px] rounded-2xl shadow-2xl overflow-hidden" style="animation: profileSlideIn 0.25s ease-out;">
      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
        <h2 class="text-lg font-bold text-[#282c3f]">Manage Addresses</h2>
        <button id="address-close-btn" class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center hover:bg-gray-200 transition-colors">
          <svg class="w-4 h-4 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="p-6 max-h-[75vh] overflow-y-auto">
        <!-- Add New Button -->
        <div class="flex justify-end mb-4">
          <button type="button" onclick="addNewAddressProfile()" class="text-[#60b246] text-sm font-bold flex items-center gap-1 hover:text-green-700">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
            Add New Address
          </button>
        </div>

        <!-- Saved Addresses List -->
        <div id="profile-address-list" class="space-y-2 mb-4"></div>

        <!-- Address Form -->
        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
          <input type="hidden" id="profile-addr-id" value="">
          <div class="mb-3">
            <label class="block text-[12px] font-semibold text-[#93959f] uppercase tracking-wider mb-1">Label <span class="text-red-500">*</span></label>
            <select id="profile-addr-label" class="w-full border border-[#d4d5d9] rounded-lg px-4 py-2.5 text-[14px] text-[#282c3f] outline-none focus:border-[#fc8019] bg-white">
              <option value="Home">Home</option>
              <option value="Work">Work</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="block text-[12px] font-semibold text-[#93959f] uppercase tracking-wider mb-1">Flat / House No <span class="text-red-500">*</span></label>
            <input type="text" id="profile-flatNo" maxlength="50" class="w-full border border-[#d4d5d9] rounded-lg px-4 py-2.5 text-[14px] text-[#282c3f] outline-none focus:border-[#fc8019]" placeholder="e.g. B-201, Flat 3A">
          </div>
          <div class="mb-3">
            <label class="block text-[12px] font-semibold text-[#93959f] uppercase tracking-wider mb-1">Address <span class="text-red-500">*</span></label>
            <input type="text" id="profile-address" maxlength="255" class="w-full border border-[#d4d5d9] rounded-lg px-4 py-2.5 text-[14px] text-[#282c3f] outline-none focus:border-[#fc8019]" placeholder="Street address, area, city">
          </div>
          <div class="mb-3">
            <label class="block text-[12px] font-semibold text-[#93959f] uppercase tracking-wider mb-1">Landmark <span class="text-red-500">*</span></label>
            <input type="text" id="profile-landmark" maxlength="255" class="w-full border border-[#d4d5d9] rounded-lg px-4 py-2.5 text-[14px] text-[#282c3f] outline-none focus:border-[#fc8019]" placeholder="Nearby landmark">
          </div>
          <div class="mb-3">
            <label class="block text-[12px] font-semibold text-[#93959f] uppercase tracking-wider mb-1">Pincode <span class="text-red-500">*</span></label>
            <input type="text" id="profile-pincode" maxlength="10" class="w-full border border-[#d4d5d9] rounded-lg px-4 py-2.5 text-[14px] text-[#282c3f] outline-none focus:border-[#fc8019]" placeholder="Pincode">
          </div>
          <div class="flex gap-2">
            <button type="button" onclick="saveProfileAddress()" class="flex-1 bg-[#60b246] text-white py-2.5 font-bold text-xs uppercase rounded-lg hover:bg-green-600 transition-colors">Save Address</button>
            <button type="button" onclick="deleteProfileAddress()" id="profile-delete-addr-btn" class="hidden bg-red-50 text-red-500 py-2.5 px-3 font-bold text-xs uppercase rounded-lg hover:bg-red-100 transition-colors border border-red-200">Delete</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes profileSlideIn {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
(function() {
  var profileModal = document.getElementById('profile-modal');
  var profileBackdrop = document.getElementById('profile-backdrop');
  var profileCloseBtn = document.getElementById('profile-close-btn');
  var addressModal = document.getElementById('address-modal');
  var addressBackdrop = document.getElementById('address-backdrop');
  var addressCloseBtn = document.getElementById('address-close-btn');

  function openProfileModal() {
    profileModal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    loadProfileData();
  }
  function closeProfileModal() {
    profileModal.classList.add('hidden');
    document.body.style.overflow = '';
  }
  function openAddressModal() {
    addressModal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    loadSavedAddresses();
  }
  function closeAddressModal() {
    addressModal.classList.add('hidden');
    document.body.style.overflow = '';
  }

  window.openProfileModal = openProfileModal;
  window.openAddressModal = openAddressModal;

  // Strict validation helper
  function validateField(value, name, opts) {
    value = (value || '').trim();
    if (opts.required && !value) return name + ' is required';
    if (opts.minLength && value.length < opts.minLength) return name + ' must be at least ' + opts.minLength + ' characters';
    if (opts.maxLength && value.length > opts.maxLength) return name + ' must be at most ' + opts.maxLength + ' characters';
    if (opts.pattern && !opts.pattern.test(value)) return name + ' format is invalid';
    return null;
  }

  async function loadProfileData() {
    try {
      var res = await fetch('/auth/profile');
      if (!res.ok) return;
      var user = await res.json();
      document.getElementById('profile-name').value = user.name || '';
      document.getElementById('profile-phone').value = user.phone || '';
      document.getElementById('profile-email').value = user.email || '';
      // Lock email field if user already has an email
      if (user.email) {
        document.getElementById('profile-email').disabled = true;
        document.getElementById('profile-email').removeAttribute('required');
        document.getElementById('profile-email-lock-hint').classList.remove('hidden');
      } else {
        document.getElementById('profile-email').disabled = false;
        document.getElementById('profile-email').setAttribute('required', '');
        document.getElementById('profile-email-lock-hint').classList.add('hidden');
      }
    } catch (e) {
      console.error('Failed to load profile', e);
    }
  }

  async function loadSavedAddresses() {
    try {
      var res = await fetch('/addresses');
      var addresses = await res.json();
      var list = document.getElementById('profile-address-list');
      if (!list) return;
      list.innerHTML = '';
      addresses.forEach(function(addr) {
        var card = document.createElement('label');
        card.className = 'flex items-start gap-2 p-2.5 border rounded-lg cursor-pointer transition-colors text-sm ' + (addr.isDefault ? 'border-[#fc8019] bg-orange-50' : 'border-gray-200 hover:border-gray-300');
        card.innerHTML = '<input type="radio" name="profile-selected-addr" value="' + addr.id + '" class="mt-0.5 accent-[#fc8019]" ' + (addr.isDefault ? 'checked' : '') + ' onchange="selectProfileAddress(' + addr.id + ')">' +
          '<div class="flex-1 min-w-0">' +
          '<div class="flex items-center gap-1.5 mb-0.5"><span class="text-[10px] font-bold text-[#fc8019] uppercase">' + addr.label + '</span>' +
          (addr.isDefault ? '<span class="text-[10px] text-gray-400">Default</span>' : '') + '</div>' +
          '<p class="text-xs text-[#3d4152] truncate">' + [addr.flatNo, addr.address, addr.landmark, addr.pincode].filter(Boolean).join(', ') + '</p>' +
          '</div>';
        list.appendChild(card);
      });
      if (addresses.length > 0) {
        var defaultAddr = addresses.find(function(a) { return a.isDefault; }) || addresses[0];
        populateAddressForm(defaultAddr);
      } else {
        addNewAddressProfile();
      }
    } catch (e) {
      console.error('Failed to load addresses', e);
    }
  }

  function populateAddressForm(addr) {
    document.getElementById('profile-addr-id').value = addr.id || '';
    document.getElementById('profile-addr-label').value = addr.label || 'Home';
    document.getElementById('profile-address').value = addr.address || '';
    document.getElementById('profile-flatNo').value = addr.flatNo || '';
    document.getElementById('profile-pincode').value = addr.pincode || '';
    document.getElementById('profile-landmark').value = addr.landmark || '';
    var delBtn = document.getElementById('profile-delete-addr-btn');
    if (delBtn) delBtn.classList.toggle('hidden', !addr.id);
  }

  window.selectProfileAddress = function(addrId) {
    fetch('/addresses')
      .then(function(r) { return r.json(); })
      .then(function(addresses) {
        var addr = addresses.find(function(a) { return a.id === addrId; });
        if (addr) populateAddressForm(addr);
        document.querySelectorAll('#profile-address-list label').forEach(function(el) {
          el.classList.remove('border-[#fc8019]', 'bg-orange-50');
          el.classList.add('border-gray-200');
        });
        var selected = document.querySelector('#profile-address-list label input[value="' + addrId + '"]');
        if (selected) {
          selected.closest('label').classList.remove('border-gray-200');
          selected.closest('label').classList.add('border-[#fc8019]', 'bg-orange-50');
        }
      });
  };

  window.addNewAddressProfile = function() {
    document.getElementById('profile-addr-id').value = '';
    document.getElementById('profile-addr-label').value = 'Home';
    document.getElementById('profile-address').value = '';
    document.getElementById('profile-flatNo').value = '';
    document.getElementById('profile-pincode').value = '';
    document.getElementById('profile-landmark').value = '';
    var delBtn = document.getElementById('profile-delete-addr-btn');
    if (delBtn) delBtn.classList.add('hidden');
    document.querySelectorAll('#profile-address-list label').forEach(function(el) {
      el.classList.remove('border-[#fc8019]', 'bg-orange-50');
      el.classList.add('border-gray-200');
    });
  };

  window.saveProfileAddress = async function() {
    var addrId = document.getElementById('profile-addr-id').value;
    var label = document.getElementById('profile-addr-label').value;
    var flatNo = document.getElementById('profile-flatNo').value.trim();
    var address = document.getElementById('profile-address').value.trim();
    var landmark = document.getElementById('profile-landmark').value.trim();
    var pincode = document.getElementById('profile-pincode').value.trim();

    // Strict validation
    var err = validateField(label, 'Label', { required: true })
      || validateField(flatNo, 'Flat / House No', { required: true, maxLength: 50 })
      || validateField(address, 'Address', { required: true, minLength: 5, maxLength: 255 })
      || validateField(landmark, 'Landmark', { required: true, minLength: 3, maxLength: 255 })
      || validateField(pincode, 'Pincode', { required: true, pattern: /^[0-9]{5,6}$/ });
    if (err) { alert(err); return; }

    try {
      // Forward geocode the address to get accurate coordinates for the manual address
      var query = [flatNo, address, landmark, pincode].filter(Boolean).join(', ');
      window.RestoLocation.forwardGeocode(query, async function(coords) {
        var data = { label: label, flatNo: flatNo, address: address, landmark: landmark, pincode: pincode, isDefault: true };
        
        // If we found coordinates, use them! This ensures the "pin" is correct for this manual address
        if (coords) {
          data.lat = coords.lat;
          data.lng = coords.lng;
          // Update the global location state so distance calculations are updated immediately
          window.RestoLocation.update(coords.lat, coords.lng, query, pincode);
        }

        var url = addrId ? '/addresses/' + addrId : '/addresses';
        var method = addrId ? 'PUT' : 'POST';

        var res = await fetch(url, { method: method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
        var saved = await res.json();
        if (saved.error) { alert(saved.error); return; }
        document.getElementById('profile-addr-id').value = saved.id;
        loadSavedAddresses();
        
        // Update Navbar Location Display
        var navLabel = [flatNo, address].filter(Boolean).join(', ');
        if (pincode && navLabel.indexOf(pincode) === -1) navLabel = navLabel + ' - ' + pincode;
        var navLoc = document.getElementById('navbar-location');
        if (navLoc && navLabel) navLoc.textContent = navLabel;

        window.dispatchEvent(new CustomEvent('profile-saved', { detail: { flatNo: flatNo, address: address, landmark: landmark, pincode: pincode } }));
      });
    } catch (e) {
      alert('Failed to save address');
    }
  };

  window.deleteProfileAddress = function() {
    var addrId = document.getElementById('profile-addr-id').value;
    if (!addrId) return;
    fetch('/addresses/' + addrId, { method: 'DELETE' })
      .then(function() { loadSavedAddresses(); addNewAddressProfile(); });
  };

  window.saveProfile = async function() {
    var nameVal = document.getElementById('profile-name').value.trim();
    var phoneVal = document.getElementById('profile-phone').value.trim();
    var emailInput = document.getElementById('profile-email');
    var emailVal = emailInput.value.trim();
    var emailLocked = emailInput.disabled;

    // Strict validation (skip email if locked)
    var err = validateField(nameVal, 'Full Name', { required: true, minLength: 2, maxLength: 100 })
      || validateField(phoneVal, 'Phone Number', { required: true, pattern: /^[0-9]{10,15}$/ });
    if (!emailLocked) {
      err = err || validateField(emailVal, 'Email', { required: true, pattern: /^[^\s@]+@[^\s@]+\.[^\s@]+$/ });
    }
    if (err) { alert(err); return; }

    var btn = document.getElementById('profile-save-btn');
    btn.disabled = true;
    btn.textContent = 'Saving...';

    try {
      var body = { name: nameVal, phone: phoneVal };
      if (!emailLocked) body.email = emailVal;
      var res = await fetch('/auth/profile', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });
      var result = await res.json();
      if (result.success) {
        btn.textContent = 'Saved!';
        btn.classList.remove('bg-[#fc8019]');
        btn.classList.add('bg-green-500');
        setTimeout(function() { 
          closeProfileModal(); 
          btn.disabled = false; 
          btn.textContent = 'Save Changes'; 
          btn.classList.remove('bg-green-500'); 
          btn.classList.add('bg-[#fc8019]'); 
          if (window.location.pathname === '/checkout') window.location.reload();
        }, 800);
      } else {
        alert('Failed: ' + (result.error || 'Unknown error'));
        btn.disabled = false; btn.textContent = 'Save Changes';
      }
    } catch (e) {
      alert('Failed to save profile');
      btn.disabled = false; btn.textContent = 'Save Changes';
    }
  };

  profileBackdrop.addEventListener('click', closeProfileModal);
  profileCloseBtn.addEventListener('click', closeProfileModal);
  addressBackdrop.addEventListener('click', closeAddressModal);
  addressCloseBtn.addEventListener('click', closeAddressModal);
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') { closeProfileModal(); closeAddressModal(); } });

  // Removed duplicate saveProfile logic

  // ===== Global Location System =====
  var RESTAURANT_LAT = window.RESTAURANT_LAT || 23.5492425;
  var RESTAURANT_LNG = window.RESTAURANT_LNG || 91.4668604;
  var AVG_SPEED_KMH = 25;
  var PREP_TIME_MIN = 30;

  function toRad(deg) { return deg * Math.PI / 180; }

  function haversineDistance(lat1, lng1, lat2, lng2) {
    var R = 6371;
    var dLat = toRad(lat2 - lat1);
    var dLng = toRad(lng2 - lng1);
    var a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
      Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) *
      Math.sin(dLng / 2) * Math.sin(dLng / 2);
    var c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
    return R * c;
  }

  function formatTime(totalMin) {
    if (totalMin > 60) {
      var hours = totalMin / 60;
      if (Number.isInteger(hours)) return hours + ' hour' + (hours > 1 ? 's' : '');
      return hours.toFixed(1) + ' hours';
    }
    return totalMin + ' min' + (totalMin !== 1 ? 's' : '');
  }

  function updateCheckoutDeliveryFee(distKm) {
    fetch('/api/settings')
      .then(function(r) { return r.json(); })
      .then(function(s) {
        var rate = s.deliveryRatePer5km || 10;
        var platform = s.platformFee || 5;
        var fiveKmBlocks = Math.ceil(distKm / 5);
        var deliveryFee = fiveKmBlocks * rate;

        var feeEl = document.getElementById('checkout-delivery-fee');
        var toPayEl = document.getElementById('checkout-to-pay');
        var payBtn = document.getElementById('checkout-pay-btn');
        var itemTotalEl = document.getElementById('checkout-item-total');
        var distEl = document.getElementById('checkout-distance');

        if (feeEl) feeEl.textContent = '₹' + deliveryFee.toFixed(2);
        if (distEl) distEl.textContent = distKm.toFixed(1) + ' km';

        if (itemTotalEl) {
          var itemTotal = parseFloat(itemTotalEl.textContent.replace('₹', '')) || 0;
          var total = itemTotal + deliveryFee + platform;
          if (toPayEl) toPayEl.textContent = '₹' + total.toFixed(2);
          if (payBtn) payBtn.textContent = 'PAY ₹' + total.toFixed(2) + ' SECURELY';
        }
      })
      .catch(function() {});
  }


  // GPS Detect (using browser geolocation + Nominatim reverse geocoding)
  var gpsBtn = document.getElementById('gps-detect-btn');
  if (gpsBtn) {
    gpsBtn.addEventListener('click', function() {
      gpsBtn.querySelector('p:first-of-type').textContent = 'Detecting...';
      window.RestoLocation.detectGPS(function(result, error) {
        if (result) {
          window.RestoLocation.update(result.lat, result.lng, result.address, result.pincode);
          gpsBtn.querySelector('p:first-of-type').textContent = 'Location detected!';
          setTimeout(function() { gpsBtn.querySelector('p:first-of-type').textContent = 'Detect my location'; }, 2000);
        } else {
          alert(error || 'Could not detect location. Please try again.');
          gpsBtn.querySelector('p:first-of-type').textContent = 'Detect my location';
        }
      });
    });
  }

  // Location Search (using Nominatim via location service)
  var searchInput = document.getElementById('location-search-input');
  if (searchInput) {
    function initSearch() {
      if (window.RestoLocation && window.RestoLocation.initPlacesAutocomplete) {
        window.RestoLocation.initPlacesAutocomplete(searchInput, function(place) {
          window.RestoLocation.update(place.lat, place.lng, place.address, place.pincode);
          searchInput.value = place.address;
        });
      } else {
        setTimeout(initSearch, 300);
      }
    }
    setTimeout(initSearch, 300);
  }
})();
</script>

<script>
(function() {
  const trigger = document.getElementById('search-trigger-btn');
  const modal = document.getElementById('search-modal');
  const backdrop = document.getElementById('search-backdrop');
  const closeBtn = document.getElementById('search-close-btn');
  const input = document.getElementById('search-input');
  const emptyState = document.getElementById('search-empty-state');
  const loadingState = document.getElementById('search-loading-state');
  const itemsList = document.getElementById('search-items-list');

  let debounceTimer = null;

  function openModal() {
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    setTimeout(() => input.focus(), 100);
  }

  function closeModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
    input.value = '';
    itemsList.innerHTML = '';
    emptyState.classList.remove('hidden');
    loadingState.classList.add('hidden');
  }

  trigger.addEventListener('click', openModal);
  backdrop.addEventListener('click', closeModal);
  closeBtn.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  input.addEventListener('input', function() {
    clearTimeout(debounceTimer);
    const q = this.value.trim();
    if (!q) {
      itemsList.innerHTML = '';
      emptyState.classList.remove('hidden');
      loadingState.classList.add('hidden');
      return;
    }
    debounceTimer = setTimeout(async () => {
      emptyState.classList.add('hidden');
      loadingState.classList.remove('hidden');
      itemsList.innerHTML = '';
      try {
        const res = await fetch('/api/search?q=' + encodeURIComponent(q));
        const items = await res.json();
        loadingState.classList.add('hidden');
        if (items.length === 0) {
          itemsList.innerHTML = '<div class="py-10 text-center text-gray-400 font-medium text-sm">No dishes found for "' + q.replace(/[<>&"]/g, '') + '"</div>';
          return;
        }
        itemsList.innerHTML = items.map(item => `
          <a href="/item/${item.uid}" class="flex items-center gap-4 px-6 py-4 hover:bg-gray-50 transition-colors border-b border-gray-50 cursor-pointer">
            <div class="w-16 h-16 rounded-xl bg-gray-100 flex-shrink-0 overflow-hidden">
              ${item.image ? '<img src="' + item.image + '" class="w-full h-full object-cover">' : '<div class="w-full h-full flex items-center justify-center text-gray-300"><svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg></div>'}
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-[15px] font-bold text-[#3d4152] truncate">${item.name}</div>
              <div class="text-xs text-gray-400 font-medium">${item.category || ''}</div>
              <div class="text-sm font-bold text-[#3d4152] mt-0.5">₹${item.price}</div>
            </div>
            ${
              item.available
                ? `<div data-menu-item-id="${item.id}" class="shrink-0"><button type="button" class="btn-add px-3 py-1 text-xs font-bold rounded-lg" onclick="event.preventDefault(); event.stopPropagation(); RestoCart.add(${item.id})">ADD<span class="ml-0.5 text-[10px]">+</span></button></div>`
                : '<div data-menu-item-id="${item.id}" data-unavailable class="shrink-0"><button disabled class="px-3 py-1 text-xs font-bold rounded-lg bg-gray-100 text-gray-400 border border-gray-200">Unavailable</button></div>'
            }
          </a>
        `).join('');
        if (window.RestoCart) window.RestoCart.renderAll();
      } catch (e) {
        loadingState.classList.add('hidden');
        console.error(e);
      }
    }, 400);
  });
})();
</script>

<!-- Mobile Full-Page Search Script -->
<script>
(function() {
  var trigger = document.getElementById('mobile-search-trigger');
  var modal = document.getElementById('mobile-full-search');
  var backBtn = document.getElementById('mobile-full-search-back');
  var input = document.getElementById('mobile-full-search-input');
  var defaultEl = document.getElementById('mobile-full-search-default');
  var loadingEl = document.getElementById('mobile-full-search-loading');
  var emptyEl = document.getElementById('mobile-full-search-empty');
  var listEl = document.getElementById('mobile-full-search-list');
  var clearBtn = document.getElementById('mobile-full-search-clear');
  if (!trigger || !modal) return;

  var debounceTimer = null;

  function openModal() {
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    setTimeout(function() { input.focus(); }, 100);
  }

  function closeModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
    input.value = '';
    listEl.innerHTML = '';
    defaultEl.classList.remove('hidden');
    loadingEl.classList.add('hidden');
    emptyEl.classList.add('hidden');
    clearBtn.classList.add('hidden');
  }

  function clearResults() {
    listEl.innerHTML = '';
    emptyEl.classList.add('hidden');
    loadingEl.classList.add('hidden');
  }

  trigger.addEventListener('click', openModal);
  backBtn.addEventListener('click', closeModal);

  clearBtn.addEventListener('click', function() {
    input.value = '';
    clearResults();
    defaultEl.classList.remove('hidden');
    clearBtn.classList.add('hidden');
    input.focus();
  });

  input.addEventListener('input', function() {
    clearTimeout(debounceTimer);
    var q = this.value.trim();
    if (!q) {
      clearResults();
      defaultEl.classList.remove('hidden');
      clearBtn.classList.add('hidden');
      return;
    }
    clearBtn.classList.remove('hidden');

    debounceTimer = setTimeout(function() {
      clearResults();
      defaultEl.classList.add('hidden');
      loadingEl.classList.remove('hidden');

      fetch('/api/search?q=' + encodeURIComponent(q))
        .then(function(r) { return r.json(); })
        .then(function(items) {
          loadingEl.classList.add('hidden');
          if (!items || items.length === 0) {
            emptyEl.classList.remove('hidden');
            return;
          }
          listEl.innerHTML = items.map(function(item) {
            var img = item.image
              ? '<img src="' + item.image + '" class="w-full h-full object-cover">'
              : '<div class="w-full h-full flex items-center justify-center text-[#e9e9eb]"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg></div>';
            var liquidKeywords = ['beverage', 'tea', 'coffee', 'juice', 'shake', 'drink', 'liquid'];
            var isLiquid = liquidKeywords.some(function(k) { return (item.category || '').toLowerCase().includes(k); });
            var vegIcon = isLiquid ? '' : (item.isVeg
              ? '<span class="w-3.5 h-3.5 border border-green-600 rounded-[3px] flex items-center justify-center shrink-0"><span class="w-2 h-2 rounded-full bg-green-600"></span></span>'
              : '<span class="w-3.5 h-3.5 border border-red-600 rounded-[3px] flex items-center justify-center shrink-0"><span class="w-2 h-2 bg-red-600" style="clip-path: polygon(50% 0%, 0% 100%, 100% 100%);"></span></span>');
            var btn = item.available
              ? '<button type="button" class="btn-add px-4 py-1.5 text-[11px] font-bold rounded-lg" onclick="event.preventDefault();event.stopPropagation();RestoCart.add(\'' + item.id + '\')">ADD<span class="ml-0.5 text-[9px]">+</span></button>'
              : '<button disabled class="px-3 py-1.5 text-[11px] font-bold rounded-lg bg-[#f0f0f5] text-[#c0c2c9]">N/A</button>';
            return '<a href="/item/' + item.uid + '" class="flex items-center gap-3 px-3 py-3.5 hover:bg-[#fafafa] active:bg-[#f5f5f5] transition-colors border-b border-[#f1f1f6] last:border-0">'
              + '<div class="w-14 h-14 rounded-xl bg-[#f5f5f5] shrink-0 overflow-hidden">' + img + '</div>'
              + '<div class="flex-1 min-w-0">'
              + '<div class="flex items-center gap-1.5 mb-0.5">' + vegIcon + '<span class="text-[14px] font-bold text-[#282c3f] truncate">' + item.name + '</span></div>'
              + '<div class="text-[11px] text-[#93959f] font-medium mb-0.5">' + (item.category || '') + '</div>'
              + '<div class="text-[14px] font-bold text-[#282c3f]">&#8377;' + item.price + '</div>'
              + '</div>'
              + '<div class="shrink-0" data-menu-item-id="' + item.id + '">' + btn + '</div>'
              + '</a>';
          }).join('');
          if (window.RestoCart) window.RestoCart.renderAll();
        })
        .catch(function() {
          loadingEl.classList.add('hidden');
        });
    }, 300);
  });
})();
</script>
