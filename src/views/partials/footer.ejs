    <script>
      function handlePwaInstall() {
        if (window.__pwaInstallPrompt) {
          window.__pwaInstallPrompt.prompt();
          window.__pwaInstallPrompt.userChoice.then(function(result) {
            if (result.outcome === 'accepted') {
              var banner = document.getElementById('pwa-install-banner');
              if (banner) banner.style.display = 'none';
            }
            window.__pwaInstallPrompt = null;
          });
        } else {
          var msg = "Lazeez is already installed or your browser doesn't support automatic installation.\n\nTo install manually:\nChrome: Menu (⋮) -> 'Install App'\nSafari: Share -> 'Add to Home Screen'";
          if (window.RestoAlert) window.RestoAlert.show(msg);
          else alert(msg);
        }
      }

      // Hide banner if app is already installed, or show if prompt already fired
      (function() {
        var banner = document.getElementById('pwa-install-banner');
        if (!banner) return;

        function checkPwaStatus() {
          if (window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone || window.__pwaInstalled) {
            banner.style.display = 'none';
          } else if (window.__pwaInstallPrompt) {
            banner.style.display = 'block';
          }
        }

        window.addEventListener('pwa-prompt-ready', function() {
          banner.style.display = 'block';
        });

        window.addEventListener('pwa-installed', function() {
          banner.style.display = 'none';
        });

        // Run once on load
        checkPwaStatus();
      })();
    </script>

