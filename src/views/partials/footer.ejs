  <!-- Offer badge live sync -->
  <script>
  (function() {
    var badge = document.getElementById('offer-badge');
    if (!badge) return;
    function syncOfferBadge() {
      fetch('/offers/api/count', { headers: { Accept: 'application/json' } })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.unseenCount > 0) {
            badge.textContent = data.unseenCount;
            badge.classList.remove('hidden');
          } else {
            badge.classList.add('hidden');
          }
        })
        .catch(function() {});
    }

    // Replace 15s Polling with Real-time SSE listener
    // Listen for 'offer:new' events pushed from server via EventSource
    if (window.RestoRealtime) {
       window.RestoRealtime.on('offer:new', function() {
         syncOfferBadge();
       });
    }
  })();
  </script>

<!-- Custom Toast Alert (replaces window.alert) -->
<style>
#resto-toast {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 99999; display: none; align-items: center; justify-content: center;
  background: rgba(0,0,0,0.4); backdrop-filter: blur(4px);
}
#resto-toast.show { display: flex; }
#resto-toast-box {
  background: white; border-radius: 16px; padding: 24px; max-width: 340px; width: 90%;
  box-shadow: 0 20px 60px rgba(0,0,0,0.3); text-align: center;
  animation: resto-toast-in 0.2s ease-out;
}
@keyframes resto-toast-in { from { transform: scale(0.9); opacity: 0; } to { transform: scale(1); opacity: 1; } }
#resto-toast-msg { color: #3d4152; font-size: 14px; font-weight: 500; line-height: 1.5; margin-bottom: 16px; }
#resto-toast-ok {
  background: #fc8019; color: white; border: none; padding: 10px 32px;
  border-radius: 10px; font-size: 13px; font-weight: 700; cursor: pointer;
  text-transform: uppercase; letter-spacing: 0.5px;
}
#resto-toast-ok:hover { background: #e57317; }
</style>
<div id="resto-toast">
  <div id="resto-toast-box">
    <div id="resto-toast-msg"></div>
    <button id="resto-toast-ok">OK</button>
  </div>
</div>
<script>
(function() {
  var toast = document.getElementById('resto-toast');
  var msg = document.getElementById('resto-toast-msg');
  var ok = document.getElementById('resto-toast-ok');
  var callback = null;

  function showAlert(message, cb) {
    msg.textContent = message;
    toast.classList.add('show');
    callback = cb || null;
  }

  ok.addEventListener('click', function() {
    toast.classList.remove('show');
    if (callback) { callback(); callback = null; }
  });
  toast.addEventListener('click', function(e) {
    if (e.target === toast) {
      toast.classList.remove('show');
      if (callback) { callback(); callback = null; }
    }
  });

  window.RestoAlert = { show: showAlert };
  window.alert = function(m) { showAlert(m); };
})();
</script>



<!-- Phone OTP Modal -->
<div id="otpModal" class="fixed inset-0 z-[300] hidden items-center justify-center bg-black/40 backdrop-blur-sm">
  <div class="bg-white rounded-2xl shadow-2xl max-w-sm w-[92%] mx-4 overflow-hidden p-6">
    <div class="flex justify-between items-center mb-6">
      <h3 id="otpModalTitle" class="text-xl font-bold text-gray-900">Enter Phone Number</h3>
      <button onclick="RestoAuth.closeOtpModal()" class="w-8 h-8 rounded-full bg-gray-100 hover:bg-gray-200 flex items-center justify-center">
        <svg class="w-4 h-4 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <!-- Phone Input Step -->
    <div id="otpPhoneStep">
      <label class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label>
      <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden focus-within:border-orange-500 transition-colors">
        <span class="px-3 py-3 bg-gray-50 text-sm font-semibold text-gray-700 border-r border-gray-300 shrink-0">+91</span>
        <input type="tel" id="otpPhoneInput" placeholder="Enter 10-digit number" maxlength="10" class="w-full px-3 py-3 text-sm outline-none bg-transparent">
      </div>
      <p class="text-xs text-gray-500 mt-1">We'll send a verification code to this number</p>
      <button id="otpSendBtn" onclick="RestoAuth.sendOtp()" class="w-full mt-4 bg-[#fc8019] text-white py-3 rounded-lg font-bold text-sm uppercase hover:shadow-md transition-shadow">
        Send OTP
      </button>
      <div id="otpRecaptchaContainer"></div>
    </div>

    <!-- OTP Verification Step -->
    <div id="otpVerifyStep" class="hidden">
      <label class="block text-sm font-medium text-gray-700 mb-1">Enter OTP</label>
      <input type="text" id="otpCodeInput" placeholder="6-digit code" maxlength="6" class="w-full px-3 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:border-orange-500 tracking-widest text-center text-lg font-mono">
      <p id="otpPhoneDisplay" class="text-xs text-gray-500 mt-1"></p>
      <button id="otpVerifyBtn" onclick="RestoAuth.verifyOtp()" class="w-full mt-4 bg-[#fc8019] text-white py-3 rounded-lg font-bold text-sm uppercase hover:shadow-md transition-shadow">
        Verify OTP
      </button>
      <button onclick="document.getElementById('otpPhoneStep').classList.remove('hidden'); document.getElementById('otpVerifyStep').classList.add('hidden'); document.getElementById('otpModalTitle').textContent = 'Enter Phone Number';" class="w-full mt-2 text-orange-500 text-sm font-medium py-2 hover:underline">
        Change phone number
      </button>
    </div>
  </div>
</div>
</body>
