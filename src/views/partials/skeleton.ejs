<!-- Skeleton Components -->
<style>
  .skeleton-pulse {
    animation: skeleton-pulse 1.5s ease-in-out infinite;
  }
  @keyframes skeleton-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
</style>

<template id="skeleton-item-card">
  <div class="group">
    <div class="relative">
      <div class="relative w-full aspect-[4/3] rounded-[16px] bg-gray-200 skeleton-pulse mb-3"></div>
    </div>
    <div class="px-1">
      <div class="h-5 w-3/4 bg-gray-200 rounded skeleton-pulse mb-2"></div>
      <div class="flex items-center gap-2 mb-1">
        <div class="h-4 w-12 bg-gray-200 rounded-full skeleton-pulse"></div>
      </div>
      <div class="h-5 w-1/2 bg-gray-200 rounded skeleton-pulse mb-1"></div>
      <div class="h-4 w-full bg-gray-200 rounded skeleton-pulse"></div>
    </div>
  </div>
</template>

<!-- Category Circle Skeleton -->
<template id="skeleton-category">
  <div class="flex flex-col items-center gap-2 shrink-0">
    <div class="w-[124px] h-[124px] rounded-full bg-gray-200 skeleton-pulse"></div>
    <div class="h-5 w-20 bg-gray-200 rounded skeleton-pulse"></div>
  </div>
</template>

<!-- Item Row Skeleton -->
<template id="skeleton-item-row">
  <div class="flex justify-between items-start border-b border-subtle pb-10">
    <div class="flex-1 min-w-0 pr-3 sm:pr-4">
      <div class="h-4 w-4 bg-gray-200 rounded-sm skeleton-pulse mb-1"></div>
      <div class="h-6 w-1/3 bg-gray-200 rounded skeleton-pulse mb-2"></div>
      <div class="h-4 w-full bg-gray-200 rounded skeleton-pulse mb-1"></div>
      <div class="h-4 w-2/3 bg-gray-200 rounded skeleton-pulse"></div>
    </div>
    <div class="relative w-[118px] h-[96px] sm:w-[156px] sm:h-[144px] flex-shrink-0">
      <div class="w-full h-full rounded-xl bg-gray-200 skeleton-pulse"></div>
    </div>
  </div>
</template>
