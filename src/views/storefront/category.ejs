<%- include('../partials/header') %>

<div class="max-w-[1200px] mx-auto px-4 sm:px-6 pt-10 pb-20">

  <nav class="flex items-center gap-2 text-sm mb-8 animate-fade-in">
    <a href="/" class="text-[#686b78] hover:text-orange-500 transition-colors">Home</a>
    <span class="text-[#686b78]/50">/</span>
    <span class="text-[#3d4152] font-semibold"><%= category.name %></span>
  </nav>

  <div class="relative mb-12 group overflow-hidden rounded-[24px] shadow-xl animate-slide-up">
    <% if (category.image) { %>
      <div class="w-full h-56 sm:h-72 overflow-hidden relative">
        <img src="<%= category.image %>" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" alt="<%= category.name %>">
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
      </div>
    <% } else { %>
      <div class="w-full h-56 sm:h-72 bg-gradient-to-br from-orange-400 to-orange-600"></div>
    <% } %>
    
    <div class="absolute bottom-0 left-0 p-6 sm:p-10 w-full">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-white/10 backdrop-blur-md rounded-full mb-3 border border-white/20">
        <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
        <span class="text-[10px] sm:text-xs font-bold text-white uppercase tracking-widest">Freshly Prepared</span>
      </div>
      <h1 class="text-3xl sm:text-5xl font-black text-white tracking-tight leading-tight mb-2 opacity-0 animate-slide-up" style="animation-fill-mode: forwards;"><%= category.name %></h1>
      <p class="text-white/80 text-sm sm:text-base font-medium max-w-xl opacity-0 animate-slide-up" style="animation-delay: 0.1s; animation-fill-mode: forwards;">Discover our chef's special <%= category.name.toLowerCase() %> selection, made to order using authentic recipes and local ingredients.</p>
    </div>
  </div>

  <% 
    const liquidCategories = ['beverage', 'tea', 'coffee', 'juice', 'shake', 'drink', 'liquid'];
    const isLiquidCategory = liquidCategories.some(keyword => category.name.toLowerCase().includes(keyword));
  %>

  <div class="sticky top-[80px] z-40 bg-white/80 backdrop-blur-xl border-b border-gray-100 -mx-4 px-4 py-4 mb-10 transition-all duration-300" id="filter-bar">
    <div class="max-w-[1200px] mx-auto flex flex-col md:flex-row md:items-center justify-between gap-4">
      <div class="flex items-center gap-2 overflow-x-auto pb-2 md:pb-0 custom-scroll no-scrollbar" id="food-type-filters">
        <button data-type="all" onclick="filterItems('all')" 
           class="filter-btn border border-subtle rounded-full px-4 py-1.5 text-sm font-semibold whitespace-nowrap transition-all duration-300 <%= currentFoodType === 'all' ? 'bg-[#3d4152] text-white border-[#3d4152]' : 'text-[#3d4152] bg-white hover:bg-gray-50' %>">
          All
        </button>

        <button data-type="veg" onclick="filterItems('veg')"
           class="filter-btn border border-subtle rounded-full px-4 py-1.5 text-sm font-semibold whitespace-nowrap transition-all duration-300 <%= currentFoodType === 'veg' ? 'bg-[#3d4152] text-white border-[#3d4152]' : 'text-[#3d4152] bg-white hover:bg-gray-50' %>">
          Veg
        </button>
        <button data-type="nonveg" onclick="filterItems('nonveg')"
           class="filter-btn border border-subtle rounded-full px-4 py-1.5 text-sm font-semibold whitespace-nowrap transition-all duration-300 <%= currentFoodType === 'nonveg' ? 'bg-[#3d4152] text-white border-[#3d4152]' : 'text-[#3d4152] bg-white hover:bg-gray-50' %>">
          Non-Veg
        </button>
        <button data-type="bestseller" onclick="filterItems('bestseller')"
           class="filter-btn border border-subtle rounded-full px-4 py-1.5 text-sm font-semibold whitespace-nowrap transition-all duration-300 <%= currentFoodType === 'bestseller' ? 'bg-[#3d4152] text-white border-[#3d4152]' : 'text-[#3d4152] bg-white hover:bg-gray-50' %>">
          Best Seller
        </button>
      </div>
      
      <div class="flex items-center justify-between md:justify-end gap-4 min-w-[140px]">
        <div id="results-count" class="text-sm font-bold text-[#3d4152]">
          <%= menuItems.length %> options available
        </div>
      </div>
    </div>
  </div>

  <div id="items-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-12 transition-all duration-500">
    <% if (menuItems.length === 0) { %>
      <div class="col-span-full py-20 text-center animate-fade-in">
        <div class="mb-4 flex justify-center">
          <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center text-gray-300">
            <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
            </svg>
          </div>
        </div>
        <h3 class="text-xl font-bold text-[#3d4152]">No dishes found</h3>
        <p class="text-gray-500">We're updating our menu. Try a different filter or category!</p>
      </div>
    <% } %>

    <% menuItems.forEach((item, index) => { %>
      <div class="group animate-slide-up" data-animate-index="<%= index %>">

        <div class="relative mb-4">
          <a href="/item/<%= item.uid %>" class="block">
            <div class="relative w-full aspect-[4/3] rounded-[24px] overflow-hidden bg-gray-100 shadow-md transform group-hover:-translate-y-1 transition-all duration-500 cursor-pointer <%= !item.available ? 'grayscale opacity-60' : '' %>">
              <% if (item.image) { %>
                <img src="<%= item.image %>" class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700" loading="lazy">
              <% } else { %>
                <div class="w-full h-full bg-gradient-to-br from-orange-50 to-orange-100 flex items-center justify-center">
                  <svg class="w-14 h-14 text-orange-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                  </svg>
                </div>
              <% } %>
              
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              
              <% if (!item.available) { %>
                <div class="absolute inset-0 z-20 flex items-center justify-center backdrop-blur-[2px]">
                  <span class="bg-black/80 text-white font-bold text-xs px-4 py-2 rounded-xl uppercase tracking-widest shadow-2xl">Sold Out</span>
                </div>
              <% } %>
              
              <% if (item.isBestSeller) { %>
                <div class="absolute top-4 left-4 z-20">
                  <div class="flex items-center gap-1.5 bg-orange-500 text-white px-2.5 py-1 rounded-full shadow-lg shadow-orange-500/30">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                    <span class="text-[10px] font-black uppercase tracking-tighter">Bestseller</span>
                  </div>
                </div>
              <% } %>

              <% if (item.available) { %>
                <div class="absolute bottom-4 right-4 z-30 opacity-0 group-hover:opacity-100 translate-y-4 group-hover:translate-y-0 transition-all duration-500" data-menu-item-id="<%= item.id %>">
                  <button type="button" 
                          class="bg-white text-orange-500 font-black px-6 py-2 rounded-xl shadow-xl hover:bg-orange-500 hover:text-white transition-all transform active:scale-95" 
                          onclick="RestoCart.add('<%= item.id %>')">
                    ADD
                  </button>
                </div>
              <% } %>
            </div>
          </a>
        </div>


        <div class="px-1">
          <div class="flex items-center justify-between mb-1.5">
            <div class="flex items-center gap-2">
              <% if (!isLiquidCategory) { %>
                <span class="w-4 h-4 rounded-sm border-2 <%= item.isVeg ? 'border-green-600' : 'border-red-600' %> flex items-center justify-center p-[2px]">
                  <span class="w-full h-full rounded-full <%= item.isVeg ? 'bg-green-600' : 'bg-red-600' %>"></span>
                </span>
              <% } %>
              <h3 class="text-lg font-bold text-[#3d4152] truncate max-w-[150px]" title="<%= item.name %>"><%= item.name %></h3>
            </div>
            <div class="flex items-center gap-1 bg-green-50 px-2 py-0.5 rounded-lg border border-green-100">
              <svg class="w-3.5 h-3.5 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <span class="text-xs font-black text-green-700"><%= itemRatings[item.id] || 'NEW' %></span>
            </div>
          </div>
          
          <div class="flex items-center gap-2 mb-2">
            <span class="text-xl font-black text-[#3d4152]">₹<%= item.price %></span>
            <span class="text-xs text-gray-400 font-medium line-through decoration-gray-300">₹<%= Math.round(item.price * 1.2) %></span>
          </div>
          
          <p class="text-[13px] text-[#686b78] line-clamp-2 leading-relaxed h-10">
            <%= item.description || 'Experience the authentic taste of ' + item.name + ', prepared with love and tradition.' %>
          </p>
          
          <div class="mt-4 sm:hidden" data-menu-item-id="<%= item.id %>" data-full-width="true">
             <% if (item.available) { %>
                <button type="button" 
                        class="w-full bg-[#3d4152] text-white font-bold py-3 rounded-xl active:scale-95 transition-transform" 
                        onclick="RestoCart.add('<%= item.id %>')">
                  Add to Cart
                </button>
             <% } else { %>
                <button disabled class="w-full bg-gray-100 text-gray-400 font-bold py-3 rounded-xl">Out of Stock</button>
             <% } %>
          </div>

        </div>
      </div>
    <% }) %>
  </div>

</div>

<script>
const CATEGORY_ID = '<%= category.id %>';
const CATEGORY_NAME = '<%= category.name %>';
let currentFoodType = '<%= currentFoodType %>';

const liquidCategories = ['beverage', 'tea', 'coffee', 'juice', 'shake', 'drink', 'liquid'];
const isLiquidCategory = liquidCategories.some(keyword => CATEGORY_NAME.toLowerCase().includes(keyword));

function applyAnimations() {
  document.querySelectorAll('[data-animate-index]').forEach(el => {
    const index = parseInt(el.getAttribute('data-animate-index'), 10);
    el.style.animationDelay = (index * 0.05) + 's';
    el.style.animationFillMode = 'forwards';
  });
}

async function filterItems(type) {
  if (type === currentFoodType) return;
  
  // Update state UI
  const buttons = document.querySelectorAll('#food-type-filters button');
  buttons.forEach(btn => {
    if (btn.dataset.type === type) {
      btn.classList.add('bg-[#3d4152]', 'text-white', 'border-[#3d4152]');
      btn.classList.remove('bg-white', 'text-[#3d4152]');
    } else {
      btn.classList.remove('bg-[#3d4152]', 'text-white', 'border-[#3d4152]');
      btn.classList.add('bg-white', 'text-[#3d4152]');
    }
  });

  currentFoodType = type;
  
  // Show Loading state
  const grid = document.getElementById('items-grid');
  grid.style.opacity = '0.5';
  grid.style.pointerEvents = 'none';

  try {
    const response = await fetch(`/api/menu-items?category=${CATEGORY_ID}&foodType=${type}`);
    const items = await response.json();
    
    // Update Results count
    document.getElementById('results-count').textContent = `${items.length} items`;
    
    // Update URL without reload
    const newUrl = new URL(window.location);
    newUrl.searchParams.set('foodType', type);
    window.history.pushState({}, '', newUrl);

    // Render Items
    if (items.length === 0) {
      grid.innerHTML = `
        <div class="col-span-full py-20 text-center animate-fade-in">
          <div class="mb-4 flex justify-center">
            <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center text-gray-300">
              <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
              </svg>
            </div>
          </div>
          <h3 class="text-xl font-bold text-[#3d4152]">No dishes found</h3>
          <p class="text-gray-500">We're updating our menu. Try a different filter or category!</p>
        </div>
      `;
    } else {
      grid.innerHTML = items.map((item, index) => `
        <div class="group animate-slide-up" data-animate-index="${index}">
          <div class="relative mb-4">
            <a href="/item/${item.uid}" class="block">
              <div class="relative w-full aspect-[4/3] rounded-[24px] overflow-hidden bg-gray-100 shadow-md transform group-hover:-translate-y-1 transition-all duration-500 cursor-pointer ${!item.available ? 'grayscale opacity-60' : ''}">
                ${item.image 
                  ? `<img src="${item.image}" class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700" loading="lazy">`
                  : `<div class="w-full h-full bg-gradient-to-br from-orange-50 to-orange-100 flex items-center justify-center">
                       <svg class="w-14 h-14 text-orange-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                         <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                       </svg>
                     </div>`
                }
                <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                ${!item.available ? `
                  <div class="absolute inset-0 z-20 flex items-center justify-center backdrop-blur-[2px]">
                    <span class="bg-black/80 text-white font-bold text-xs px-4 py-2 rounded-xl uppercase tracking-widest shadow-2xl">Sold Out</span>
                  </div>
                ` : ''}
                ${item.isBestSeller ? `
                  <div class="absolute top-4 left-4 z-20">
                    <div class="flex items-center gap-1.5 bg-orange-500 text-white px-2.5 py-1 rounded-full shadow-lg shadow-orange-500/30">
                      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                      <span class="text-[10px] font-black uppercase tracking-tighter">Bestseller</span>
                    </div>
                  </div>
                ` : ''}
                ${item.available ? `
                  <div class="absolute bottom-4 right-4 z-30 opacity-0 group-hover:opacity-100 translate-y-4 group-hover:translate-y-0 transition-all duration-500" data-menu-item-id="${item.id}">
                    <button type="button" class="bg-white text-orange-500 font-black px-6 py-2 rounded-xl shadow-xl hover:bg-orange-500 hover:text-white transition-all transform active:scale-95" onclick="RestoCart.add('${item.id}')">ADD</button>
                  </div>
                ` : ''}
              </div>
            </a>
          </div>
          <div class="px-1">
            <div class="flex items-center justify-between mb-1.5">
              <div class="flex items-center gap-2">
                ${!isLiquidCategory ? `
                  <span class="w-4 h-4 rounded-sm border-2 ${item.isVeg ? 'border-green-600' : 'border-red-600'} flex items-center justify-center p-[2px]">
                    <span class="w-full h-full rounded-full ${item.isVeg ? 'bg-green-600' : 'bg-red-600'}"></span>
                  </span>
                ` : ''}
                <h3 class="text-lg font-bold text-[#3d4152] truncate max-w-[150px]" title="${item.name}">${item.name}</h3>
              </div>
              <div class="flex items-center gap-1 bg-green-50 px-2 py-0.5 rounded-lg border border-green-100">
                <svg class="w-3.5 h-3.5 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                <span class="text-xs font-black text-green-700">${item.avgRating || 'NEW'}</span>
              </div>
            </div>
            <div class="flex items-center gap-2 mb-2">
              <span class="text-xl font-black text-[#3d4152]">₹${item.price}</span>
              <span class="text-xs text-gray-400 font-medium line-through decoration-gray-300">₹${Math.round(item.price * 1.2)}</span>
            </div>
            <p class="text-[13px] text-[#686b78] line-clamp-2 leading-relaxed h-10">${item.description || 'Experience the authentic taste of ' + item.name + ', prepared with love and tradition.'}</p>
            <div class="mt-4 sm:hidden" data-menu-item-id="${item.id}" data-full-width="true">
               ${item.available 
                 ? `<button type="button" class="w-full bg-[#3d4152] text-white font-bold py-3 rounded-xl active:scale-95 transition-transform" onclick="RestoCart.add('${item.id}')">Add to Cart</button>`
                 : `<button disabled class="w-full bg-gray-100 text-gray-400 font-bold py-3 rounded-xl">Out of Stock</button>`
               }
            </div>
          </div>
        </div>
      `).join('');
      
      applyAnimations();
      if (window.RestoCart) window.RestoCart.renderAll();
    }

  } catch (err) {
    console.error('Filtering error:', err);
  } finally {
    grid.style.opacity = '1';
    grid.style.pointerEvents = 'auto';
  }
}

// Add scroll listener for sticky bar effects
window.addEventListener('scroll', () => {
    const filterBar = document.getElementById('filter-bar');
    if (window.scrollY > 300) {
        filterBar.classList.add('shadow-md', 'py-2');
        filterBar.classList.remove('py-4');
    } else {
        filterBar.classList.remove('shadow-md', 'py-2');
        filterBar.classList.add('py-4');
    }
});

document.addEventListener('DOMContentLoaded', applyAnimations);
</script>


<style>
@keyframes fade-in {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes slide-up {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
.animate-fade-in {
  animation: fade-in 0.6s ease-out;
}
.animate-slide-up {
  opacity: 0;
  animation: slide-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}
.no-scrollbar::-webkit-scrollbar {
  display: none;
}
.no-scrollbar {
  -ms-overflow-style: none;
  scrollbar-width: none;
}
</style>

<%- include('../partials/footer') %>