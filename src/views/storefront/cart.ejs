<%- include('../partials/header') %>

<div class="bg-[#f1f1f6] min-h-[80vh] flex flex-col items-center py-10 px-4">
  
  <div class="max-w-[700px] w-full mb-6">
    <a href="/" class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-white shadow-sm border border-[#e9e9eb] text-[#686b78] hover:text-[#fc8019] transition-all active:scale-95 group">
      <svg class="w-5 h-5 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
      </svg>
    </a>
  </div>
  
  <div class="max-w-[700px] w-full" id="cart-container">
    
    <div id="cart-empty" class="<%= cart.length === 0 ? '' : 'hidden' %>">
      <div class="bg-white p-12 text-center flex flex-col items-center shadow-sm">
        <div class="w-48 h-48 sm:w-64 sm:h-72 mb-6 flex items-center justify-center bg-gray-50 rounded-full">
          <svg class="w-32 h-32 text-gray-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-[#535665] mb-2 font-sans">Your cart is empty</h3>
        <a href="/menu" class="mt-4 inline-block bg-[#fc8019] text-white font-bold py-3 px-8 rounded-xl text-sm uppercase tracking-wider hover:shadow-md transition-shadow">Browse Menu</a>
      </div>
    </div>
    
    <div id="cart-content" class="<%= cart.length > 0 ? '' : 'hidden' %>">
      
      <div class="bg-white p-6 mb-4 flex items-center gap-4 shadow-sm">
        <div class="w-16 h-16 bg-orange-100 flex items-center justify-center shrink-0 hidden sm:flex">
          <span class="text-orange-500 font-bold text-xl">R</span>
        </div>
        <div>
          <h2 class="text-lg font-bold text-[#282c3f]">Lazeez Signature</h2>
          <p class="text-xs text-[#7e808c]">Downtown Area</p>
          <div class="w-10 h-[2px] bg-[#282c3f] mt-3"></div>
        </div>
      </div>

      <div class="bg-white p-6 mb-4 shadow-sm">
        <div class="space-y-6" id="cart-items">
          <% cart.forEach(item => { %>
            <div class="flex justify-between items-center group cart-item-row" data-item-id="<%= item.id %>">
              
              <div class="flex items-center gap-3 w-1/2">
                <svg class="w-3.5 h-3.5 flex-shrink-0 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="12" cy="12" r="4" fill="currentColor"></circle></svg>
                <div class="text-[14px] text-[#3d4152] font-medium truncate"><%= item.name %></div>
              </div>
              
              <div class="flex items-center gap-4 justify-end w-1/2">
                <% var itemId = item.id; var itemQty = item.quantity; var itemPrice = Number(item.price) || 0; %>
                <div class="border border-[#d4d5d9] bg-white text-green-600 font-bold text-sm w-[72px] h-[30px] flex items-center justify-between px-2 cursor-pointer shadow-sm">
                  <button type="button" data-action="decrement" data-item-id="<%= itemId %>" data-new-qty="<%= itemQty - 1 %>" class="cart-qty-btn text-gray-400 hover:text-green-600 focus:outline-none bg-transparent border-none cursor-pointer<%= itemQty <= 1 ? ' pointer-events-none opacity-50 text-gray-300' : '' %>"<%= itemQty <= 1 ? ' disabled' : '' %>>−</button>
                  <span class="text-xs w-4 text-center select-none cart-item-qty"><%= itemQty %></span>
                  <button type="button" data-action="increment" data-item-id="<%= itemId %>" data-new-qty="<%= itemQty + 1 %>" class="cart-qty-btn text-green-600 hover:text-green-700 focus:outline-none bg-transparent border-none cursor-pointer">+</button>
                </div>
                
                <div class="text-[14px] text-[#535665] w-[70px] text-right cart-item-price">
                  ₹<%= (itemPrice * itemQty).toFixed(2) %>
                </div>

                <button type="button" data-action="remove" data-item-id="<%= itemId %>" class="cart-remove-btn text-gray-300 hover:text-red-500 transition-colors focus:outline-none bg-transparent border-none cursor-pointer hidden sm:block" title="Remove Item">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
              </div>

            </div>
          <% }) %>
        </div>

        <div class="h-14 mt-4 w-full bg-[#f9f9f9] border border-dashed border-[#a9abb2] flex items-center px-4 overflow-hidden rounded-sm cursor-text text-sm hover:shadow-inner transition-shadow">
          <svg class="w-4 h-4 text-gray-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122"/></svg>
          <input type="text" placeholder="Any suggestions? We will pass it on..." class="bg-transparent border-none outline-none w-full text-gray-700 placeholder-[#93959f] text-[13px] font-medium">
        </div>
      </div>

      <div class="bg-white p-6 shadow-sm mb-4">
        <h3 class="text-[#282c3f] font-bold text-[14px] mb-4">Bill Details</h3>
        
        <div class="space-y-2 text-[13px] text-[#686b78] border-b border-[#e9e9eb] pb-3">
          <div class="flex justify-between">
            <span>Item Total</span>
            <span id="cart-item-total">₹<%= total.toFixed(2) %></span>
          </div>
          <div class="flex justify-between">
            <span id="cart-delivery-fee-label">Delivery Fee | <span id="cart-distance">...</span></span>
            <span id="cart-delivery-fee-display">Calculated at checkout</span>
          </div>
          <div class="flex justify-between text-orange-500">
            <span>Platform fee</span>
            <span>₹<%= platformFee.toFixed(2) %></span>
          </div>
        </div>

        <div class="flex justify-between items-center text-[15px] font-bold text-[#282c3f] py-4">
          <span>TO PAY</span>
          <span id="cart-to-pay">₹<%= (total + platformFee).toFixed(2) %> + delivery</span>
        </div>
      </div>

      <div class="bg-white p-5 shadow-sm mb-4">
        <div class="flex items-center gap-3 mb-2">
          <svg class="w-5 h-5 text-orange-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span class="text-[14px] font-bold text-[#282c3f]">Estimated delivery: <span id="cart-delivery-time" class="text-orange-500">...</span></span>
        </div>
        <p class="text-[12px] text-[#7e808c] leading-relaxed ml-8">
          We are trying to deliver your order by this time, but it may take a few minutes more. This can be due to traffic, weather, or other circumstances.
        </p>
      </div>

      <div class="mt-4 pb-0">
        <a href="/checkout" class="block w-full text-center bg-[#60b246] text-white font-bold py-4 rounded text-[15px] uppercase tracking-wide hover:shadow-lg hover:bg-green-600 transition-all cursor-pointer">
          PROCEED TO CHECKOUT
        </a>
      </div>

    </div>
  </div>
</div>

<script type="application/json" id="cart-config-data"><%- JSON.stringify({ platformFee: platformFee, deliveryRatePer5km: deliveryRatePer5km }) %></script>
<script>
(function() {
  var __cartConfig = JSON.parse(document.getElementById('cart-config-data').textContent);
  var PLATFORM_FEE = __cartConfig.platformFee;
  var DELIVERY_RATE_PER_5KM = __cartConfig.deliveryRatePer5km;
  var RESTAURANT_LAT = window.RESTAURANT_LAT || 23.5492425;
  var RESTAURANT_LNG = window.RESTAURANT_LNG || 91.4668604;
  var deliveryFee = 0;

  function getItems() {
    return window.RestoCartState ? window.RestoCartState.items || [] : [];
  }

  function calcTotal(items) {
    return items.reduce(function(sum, i) { return sum + (Number(i.price) || 0) * (Number(i.quantity) || 0); }, 0);
  }

  function updateBill(items) {
    var total = calcTotal(items);
    var itemTotal = document.getElementById('cart-item-total');
    var toPay = document.getElementById('cart-to-pay');
    if (itemTotal) itemTotal.textContent = '₹' + total.toFixed(2);
    if (toPay) toPay.textContent = '₹' + (total + PLATFORM_FEE).toFixed(2) + ' + delivery';
  }

  function renderRow(item) {
    var row = document.querySelector('.cart-item-row[data-item-id="' + item.id + '"]');
    if (!row) return;
    var qtyEl = row.querySelector('.cart-item-qty');
    var priceEl = row.querySelector('.cart-item-price');
    var buttons = row.querySelectorAll('button');
    var minusBtn = buttons[0];
    var plusBtn = buttons[1];
    if (qtyEl) qtyEl.textContent = item.quantity;
    if (priceEl) priceEl.textContent = '₹' + ((Number(item.price) || 0) * (Number(item.quantity) || 0)).toFixed(2);
    if (minusBtn) {
      if (item.quantity <= 1) {
        minusBtn.classList.add('pointer-events-none', 'opacity-50', 'text-gray-300');
        minusBtn.setAttribute('disabled', '');
      } else {
        minusBtn.classList.remove('pointer-events-none', 'opacity-50', 'text-gray-300');
        minusBtn.removeAttribute('disabled');
      }
      minusBtn.setAttribute('onclick', 'cartPage.updateQty(' + item.id + ',' + (item.quantity - 1) + ')');
    }
    if (plusBtn) {
      plusBtn.setAttribute('onclick', 'cartPage.updateQty(' + item.id + ',' + (item.quantity + 1) + ')');
    }
  }

  function removeRow(itemId) {
    var row = document.querySelector('.cart-item-row[data-item-id="' + itemId + '"]');
    if (row) {
      row.style.transition = 'opacity 0.3s, transform 0.3s';
      row.style.opacity = '0';
      row.style.transform = 'translateX(-20px)';
      setTimeout(function() { row.remove(); }, 300);
    }
  }

  function showEmptyState() {
    document.getElementById('cart-content').classList.add('hidden');
    document.getElementById('cart-empty').classList.remove('hidden');
  }

  window.cartPage = {
    updateQty: function(itemId, newQty) {
      RestoCart.update(itemId, newQty).then(function() {
        var items = getItems();
        var item = items.find(function(i) { return i.id === itemId; });
        if (item) {
          renderRow(item);
        } else {
          removeRow(itemId);
        }
        updateBill(items);
        if (items.length === 0) {
          setTimeout(showEmptyState, 350);
        }
      }).catch(function(err) {
        console.error('Failed to update cart quantity:', err);
      });
    },
    removeItem: function(itemId) {
      RestoCart.remove(itemId).then(function() {
        removeRow(itemId);
        var items = getItems();
        updateBill(items);
        if (items.length === 0) {
          setTimeout(showEmptyState, 350);
        }
      }).catch(function(err) {
        console.error('Failed to remove cart item:', err);
      });
    }
  };

  // Event delegation for cart quantity/remove buttons
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('[data-action]');
    if (!btn) return;
    var action = btn.getAttribute('data-action');
    var id = btn.getAttribute('data-item-id');
    if (action === 'decrement' || action === 'increment') {
      var newQty = parseInt(btn.getAttribute('data-new-qty'), 10);
      cartPage.updateQty(id, newQty);
    } else if (action === 'remove') {
      cartPage.removeItem(id);
    }
  });
})();
</script>

<%- include('../partials/footer') %>