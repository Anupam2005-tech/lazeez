            <div class="w-10 h-[3px] bg-[#fc8019] rounded-full"></div>
          </div>
        </div>
        <div class="pl-[52px] space-y-3 text-[14px] text-[#686b78] leading-relaxed">
          <p>We use cookies and similar technologies to enhance your experience on our Platform:</p>
          <div class="border border-[#e9e9eb] rounded-lg overflow-hidden my-3">
            <table class="w-full text-[13px]">
              <thead>
                <tr class="bg-orange-50/60">
                  <th class="text-left px-4 py-2.5 text-[10px] font-bold text-[#fc8019] uppercase tracking-wider">Cookie Type</th>
                  <th class="text-left px-4 py-2.5 text-[10px] font-bold text-[#fc8019] uppercase tracking-wider">Purpose</th>
                  <th class="text-left px-4 py-2.5 text-[10px] font-bold text-[#fc8019] uppercase tracking-wider hidden sm:table-cell">Duration</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-[#f1f1f6]">
