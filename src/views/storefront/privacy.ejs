          </div>
          <div>
            <h2 class="text-xl font-black text-[#3d4152] mb-1">2. How We Use Your Information</h2>
            <div class="w-10 h-[3px] bg-[#fc8019] rounded-full"></div>
          </div>
        </div>
        <div class="pl-[52px] space-y-3 text-[14px] text-[#686b78] leading-relaxed">
          <p>We use the information we collect for the following purposes:</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2.5 my-4">
            <div class="bg-orange-50/50 border border-orange-100 rounded-lg p-3.5">
              <div class="text-[11px] font-bold text-[#fc8019] uppercase tracking-wider mb-0.5">Order Fulfilment</div>
              <div class="text-[12px] text-[#686b78]">Process, deliver, and manage your food orders</div>
            </div>
            <div class="bg-orange-50/50 border border-orange-100 rounded-lg p-3.5">
              <div class="text-[11px] font-bold text-[#fc8019] uppercase tracking-wider mb-0.5">Account Management</div>
              <div class="text-[12px] text-[#686b78]">Create, maintain, and secure your account</div>
            </div>
            <div class="bg-orange-50/50 border border-orange-100 rounded-lg p-3.5">
              <div class="text-[11px] font-bold text-[#fc8019] uppercase tracking-wider mb-0.5">Communication</div>
              <div class="text-[12px] text-[#686b78]">Send order updates, receipts, and support</div>
            </div>
            <div class="bg-orange-50/50 border border-orange-100 rounded-lg p-3.5">
              <div class="text-[11px] font-bold text-[#fc8019] uppercase tracking-wider mb-0.5">Improvement</div>
              <div class="text-[12px] text-[#686b78]">Analyse usage to improve our service quality</div>
            </div>
            <div class="bg-orange-50/50 border border-orange-100 rounded-lg p-3.5">
              <div class="text-[11px] font-bold text-[#fc8019] uppercase tracking-wider mb-0.5">Security</div>
              <div class="text-[12px] text-[#686b78]">Detect fraud and prevent unauthorized access</div>
            </div>
            <div class="bg-orange-50/50 border border-orange-100 rounded-lg p-3.5">
              <div class="text-[11px] font-bold text-[#fc8019] uppercase tracking-wider mb-0.5">Promotions</div>
              <div class="text-[12px] text-[#686b78]">Share relevant offers and recommendations</div>
            </div>
          </div>
        </div>
      </section>

      <!-- Section 3 -->
      <section id="sharing" class="scroll-mt-32 border-t border-[#f1f1f6] pt-10">
        <div class="flex items-start gap-3.5 mb-5">
          <div class="w-9 h-9 rounded-lg bg-orange-50 flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-4.5 h-4.5 text-[#fc8019]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
