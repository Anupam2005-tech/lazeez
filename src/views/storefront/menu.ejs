<%- include('../partials/header') %>

<div class="max-w-[800px] mx-auto px-4 sm:px-6 pt-10 pb-20">
  
  <!-- Breadcrumb -->
  <div class="flex text-[10px] text-[#93959f] font-medium tracking-tight mb-8">
    <span>Home</span>
    <span class="mx-2">/</span>
    <span>City</span>
    <span class="mx-2">/</span>
    <span class="text-[#3d4152]">Lazeez</span>
  </div>

  <!-- Restaurant Header (Swiggy UI) -->
  <div class="flex justify-between items-start border-b border-subtle border-dashed pb-6 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-[#282c3f] mb-2 tracking-tight">Lazeez</h1>
      <p class="text-[13px] text-[#7e808c] mb-1">Pizzas, Fast Food, North Indian</p>
      <div class="flex items-center text-[13px] text-[#7e808c] gap-2">
        <span>Dhajanagar,Udaipur Gomati Tripura</span>
      </div>
    </div>

    <!-- Rating block on the right -->
    <div class="border border-subtle rounded-lg p-2 text-center shadow-sm">
      <div class="flex items-center justify-center text-green-600 font-bold border-b border-subtle pb-2 mb-2">
        <svg class="w-4 h-4 mr-1" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        <%= storeRating %>
      </div>
      <div class="text-[11px] text-[#8b8d97] font-semibold tracking-tighter">
        <%= (storeRatingCount >= 1000) ? (storeRatingCount/1000).toFixed(1) + 'K+' : storeRatingCount %> ratings
      </div>
    </div>
  </div>

  <!-- Search / Filters inside Menu -->
  <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 mb-8">
    <!-- Search Bar (AJAX) -->
    <div class="relative w-full">
      <div class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none">
        <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
      </div>
      <input type="text" id="menu-search-input" placeholder="Search for dishes..." value="<%= searchQuery %>"
             class="block w-full bg-gray-100 rounded-xl px-4 py-3 text-[15px] font-medium text-gray-800 placeholder-gray-500 border-none focus:ring-0 focus:bg-[#f1f1f6] transition-colors outline-none">
    </div>
  </div>

  <!-- Dual Dropdown Filters -->
  <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 mb-8">
    <div class="flex-1 w-full">
      <label class="text-[10px] font-bold text-[#7e808c] uppercase tracking-wider block mb-1">Category</label>
      <select id="menu-category-select" onchange="filterByCategory(this.value)" 
              class="w-full bg-white border border-[#e9e9eb] rounded-xl px-3 py-2.5 text-sm font-semibold text-[#3d4152] outline-none focus:ring-2 focus:ring-orange-500/30 transition-all">
        <option value="null" <%= !currentCategory ? 'selected' : '' %>>All Categories</option>
        <% categories.forEach(cat => { %>
          <option value="<%= cat.id %>" <%= currentCategory === cat.id ? 'selected' : '' %>> <%= cat.name %> </option>
        <% }) %>
      </select>
    </div>
    <div class="flex-1 w-full">
      <label class="text-[10px] font-bold text-[#7e808c] uppercase tracking-wider block mb-1">Food Type</label>
      <select id="menu-food-type-select" onchange="filterByFoodType(this.value)" 
              class="w-full bg-white border border-[#e9e9eb] rounded-xl px-3 py-2.5 text-sm font-semibold text-[#3d4152] outline-none focus:ring-2 focus:ring-orange-500/30 transition-all">
        <option value="all" <%= (!currentFoodType || currentFoodType === 'all') ? 'selected' : '' %>>All</option>
        <option value="veg" <%= currentFoodType === 'veg' ? 'selected' : '' %>>Veg</option>
        <option value="nonveg" <%= currentFoodType === 'nonveg' ? 'selected' : '' %>>Non-Veg</option>
        <option value="bestseller" <%= currentFoodType === 'bestseller' ? 'selected' : '' %>>Best Seller</option>
      </select>
    </div>
  </div>

  <!-- Items List Container -->
  <div id="menu-items-container">
    <h3 id="menu-heading" class="text-xl font-extrabold text-[#3d4152] tracking-tight mt-8 mb-6">
      Recommended (<%= menuItems.length %>)
    </h3>

    <div id="menu-items-list" class="flex flex-col gap-10">
      <% if (menuItems.length === 0) { %>
        <div class="py-12 text-center text-gray-500">No dishes found.</div>
      <% } %>

      <% menuItems.forEach(item => { %>
        <div class="menu-item-row flex justify-between items-start border-b border-subtle pb-10 group <%= !item.available ? 'opacity-50' : '' %>">
          <div class="flex-1 min-w-0 pr-3 sm:pr-4">
            <% 
              const liquidKeywords = ['beverage', 'tea', 'coffee', 'juice', 'shake', 'drink', 'liquid'];
              const isLiquid = liquidKeywords.some(k => (item.category || '').toLowerCase().includes(k));
            %>
            <% if (!isLiquid) { %>
              <% if (item.isVeg) { %>
                <svg class="w-4 h-4 mb-1 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="12" cy="12" r="4" fill="currentColor"></circle></svg>
              <% } else { %>
                <svg class="w-4 h-4 mb-1 text-red-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><path d="M12 8l4 8H8l4-8z" fill="currentColor"></path></svg>
              <% } %>
            <% } %>
            
             <a href="/item/<%= item.uid %>" class="block">
               <h3 class="text-lg font-bold text-[#3d4152] leading-tight mb-1 group-hover:text-orange-500 transition-colors"><%= item.name %></h3>
             </a>
                <div class="font-medium text-[#3d4152] text-[15px] mb-3">₹<%= Number(item.price).toFixed(2) %></div>
             <p class="text-[#282c3f]/60 text-sm leading-relaxed line-clamp-2 pr-4 font-light"><%= item.description %></p>
          </div>

          <div class="relative w-[118px] h-[96px] sm:w-[156px] sm:h-[144px] flex-shrink-0">
            <a href="/item/<%= item.uid %>" class="block w-full h-full">
              <div class="w-full h-full rounded-xl overflow-hidden bg-gray-100 <%= !item.available ? 'grayscale opacity-50' : '' %>">
                <% if (item.image) { %>
                  <img src="<%= item.image %>" class="w-full h-full object-cover" loading="lazy">
                <% } else { %>
                  <div class="w-full h-full flex items-center justify-center text-gray-400 text-xs">No Image</div>
                <% } %>
              </div>
            </a>
            
            <div class="absolute -bottom-5 left-1/2 -translate-x-1/2 w-[90px] sm:w-[120px]">
              <% if (item.available) { %>
                <div data-menu-item-id="<%= item.id %>">
                  <button type="button" class="btn-add w-full py-2 flex items-center justify-center" onclick="RestoCart.add('<%= item.id %>')">
                    ADD <span class="ml-1 text-[12px]">+</span>
                  </button>
                </div>
              <% } else { %>
                  <button disabled class="w-full py-2 flex items-center justify-center bg-gray-100 text-gray-400 border border-gray-200 rounded-md font-bold text-xs uppercase">Sold Out</button>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</div>

<script id="menu-data" type="application/json"><%- JSON.stringify({ currentCategory: currentCategory, currentFoodType: currentFoodType || 'all', searchQuery: searchQuery || '' }) %></script>
<script>
(function() {
  var __menuData = JSON.parse(document.getElementById('menu-data').textContent);
  var __currentCategory = __menuData.currentCategory;
  var __currentFoodType = __menuData.currentFoodType;
  var __searchQuery = __menuData.searchQuery;
  var __liquidKeywords = ['beverage', 'tea', 'coffee', 'juice', 'shake', 'drink', 'liquid'];

  function updateActiveStates() {
    document.querySelectorAll('.cat-btn').forEach(function(btn) {
      var id = btn.dataset.id === 'null' ? null : btn.dataset.id;
      if (id === __currentCategory) btn.className = 'cat-btn border border-subtle rounded-full px-4 py-1.5 text-sm font-semibold whitespace-nowrap bg-[#3d4152] text-white border-[#3d4152]';
      else btn.className = 'cat-btn border border-subtle rounded-full px-4 py-1.5 text-sm font-semibold whitespace-nowrap text-[#3d4152] bg-white hover:bg-gray-50';
    });
    document.querySelectorAll('.ft-btn').forEach(function(btn) {
      if (btn.dataset.type === __currentFoodType) btn.className = 'ft-btn border border-subtle rounded-full px-4 py-1.5 text-sm font-semibold whitespace-nowrap bg-[#3d4152] text-white border-[#3d4152]';
      else btn.className = 'ft-btn border border-subtle rounded-full px-4 py-1.5 text-sm font-semibold whitespace-nowrap text-[#3d4152] bg-white hover:bg-gray-50';
    });
  }

  var searchTimeout;
  document.getElementById('menu-search-input').addEventListener('input', function(e) {
    __searchQuery = e.target.value;
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(loadItems, 300);
  });

  document.addEventListener('click', function(e) {
    var btn = e.target.closest('[data-action]');
    if (!btn) return;
    var action = btn.dataset.action;
    if (action === 'filter-category') {
      __currentCategory = btn.dataset.id === 'null' ? null : btn.dataset.id;
      loadItems();
    } else if (action === 'filter-food-type') {
      __currentFoodType = btn.dataset.type;
      loadItems();
    }
  });

  function loadItems() {
    updateActiveStates();
    var list = document.getElementById('menu-items-list');
    
    var skeletonTpl = document.getElementById('skeleton-item-row');
    var skeletonHtml = '';
    if (skeletonTpl) {
      for (var i = 0; i < 5; i++) {
        skeletonHtml += skeletonTpl.innerHTML;
      }
    } else {
      skeletonHtml = '<div class="py-12 text-center"><svg class="w-8 h-8 animate-spin mx-auto text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4m0 12v4m-7.07-3.93l2.83-2.83m8.48-8.48l2.83-2.83M2 12h4m12 0h4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83"/></svg></div>';
    }
    list.innerHTML = skeletonHtml;
    list.style.opacity = '0.5';
    
    var params = new URLSearchParams();
    if (__currentCategory) params.set('category', __currentCategory);
    if (__currentFoodType !== 'all') params.set('foodType', __currentFoodType);
    if (__searchQuery) params.set('search', __searchQuery);
    
    fetch('/api/menu-items?' + params.toString())
      .then(r => r.json())
      .then(items => {
        document.getElementById('menu-heading').textContent = 'Recommended (' + items.length + ')';
        if (items.length === 0) {
          list.innerHTML = '<div class="py-12 text-center text-gray-500">No dishes found.</div>';
        } else {
          list.innerHTML = items.map(function(item) {
            var isLiquid = __liquidKeywords.some(function(k) { return (item.categoryName || '').toLowerCase().includes(k); });
            var dietIcon = '';
            if (!isLiquid) {
              dietIcon = item.isVeg 
                ? '<svg class="w-4 h-4 mb-1 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="12" cy="12" r="4" fill="currentColor"></circle></svg>'
                : '<svg class="w-4 h-4 mb-1 text-red-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><path d="M12 8l4 8H8l4-8z" fill="currentColor"></path></svg>';
            }
            var addBtn = item.available 
              ? '<div data-menu-item-id="'+item.id+'"><button type="button" class="btn-add w-full py-2 flex items-center justify-center" onclick="RestoCart.add(\''+item.id+'\')">ADD <span class="ml-1 text-[12px]">+</span></button></div>'
              : '<button disabled class="w-full py-2 flex items-center justify-center bg-gray-100 text-gray-400 border border-gray-200 rounded-md font-bold text-xs uppercase">Sold Out</button>';
            
            return '<div class="menu-item-row flex justify-between items-start border-b border-subtle pb-10 group '+(item.available?'':'opacity-50')+'">' +
              '<div class="flex-1 min-w-0 pr-3 sm:pr-4">' + dietIcon + 
              '<a href="/item/'+item.uid+'" class="block"><h3 class="text-lg font-bold text-[#3d4152] leading-tight mb-1 group-hover:text-orange-500 transition-colors">'+item.name+'</h3></a>' +
              '<div class="font-medium text-[#3d4152] text-[15px] mb-3">₹' + Number(item.price).toFixed(2) + '</div>' +
              '<p class="text-[#282c3f]/60 text-sm leading-relaxed line-clamp-2 pr-4 font-light">'+(item.description||'')+'</p></div>' +
              '<div class="relative w-[118px] h-[96px] sm:w-[156px] sm:h-[144px] flex-shrink-0">' +
              '<a href="/item/'+item.uid+'" class="block w-full h-full"><div class="w-full h-full rounded-xl overflow-hidden bg-gray-100 '+(item.available?'':'grayscale opacity-50')+'">' +
              (item.image ? '<img src="'+item.image+'" class="w-full h-full object-cover" loading="lazy">' : '<div class="w-full h-full flex items-center justify-center text-gray-400 text-xs">No Image</div>') +
              '</div></a><div class="absolute -bottom-5 left-1/2 -translate-x-1/2 w-[90px] sm:w-[120px]">' + addBtn + '</div></div></div>';
          }).join('');
        }
        if (window.RestoCart) window.RestoCart.renderAll();
        list.style.opacity = '1';
      });
  }
})();
</script>

<style>
.no-scrollbar::-webkit-scrollbar { display: none; }
.no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<%- include('../partials/footer') %>
