<%- include('../partials/header') %>

<div class="max-w-[800px] mx-auto px-4 py-8">
  
  <!-- Header -->
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold text-[#282c3f]">My Orders</h1>
    <a href="/" class="text-orange-500 font-semibold text-sm hover:text-orange-600 transition-colors">Order Food</a>
  </div>

  <% if (orders.length === 0) { %>
    <!-- Empty State -->
    <div class="bg-white rounded-2xl shadow-sm border border-[#e9e9eb] p-12 text-center">
      <div class="w-24 h-24 mx-auto mb-6">
        <svg class="w-full h-full text-gray-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
      </div>
      <h3 class="text-lg font-bold text-[#535665] mb-2">No orders yet</h3>
      <p class="text-[#7e808c] text-sm mb-6">Looks like you haven't ordered anything yet.</p>
      <a href="/" class="inline-block bg-orange-500 text-white font-bold px-6 py-3 rounded-xl text-sm hover:bg-orange-600 transition-colors">
        Browse Menu
      </a>
    </div>
  <% } else { %>
    <!-- Orders List -->
    <div class="space-y-4" id="orders-list">
      <% orders.forEach(order => { %>
        <% 
          let statusColor = 'bg-gray-100 text-gray-700';
          let statusDot = 'bg-gray-400';
          if (order.status === 'Pending') { statusColor = 'bg-yellow-50 text-yellow-700'; statusDot = 'bg-yellow-400'; }
          if (order.status === 'Preparing') { statusColor = 'bg-blue-50 text-blue-700'; statusDot = 'bg-blue-400'; }
          if (order.status === 'Ready') { statusColor = 'bg-indigo-50 text-indigo-700'; statusDot = 'bg-indigo-400'; }
          if (order.status === 'Delivered') { statusColor = 'bg-green-50 text-green-700'; statusDot = 'bg-green-400'; }
          if (order.status === 'Cancelled') { statusColor = 'bg-red-50 text-red-700'; statusDot = 'bg-red-400'; }
          
          const orderDate = new Date(order.createdAt);
          const dateStr = orderDate.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
          const timeStr = orderDate.toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' });
          const hasFeedback = order.feedback && order.feedback.length > 0;
        %>
        
        <a href="/orders/<%= order.id %>" data-order-id="<%= order.id %>" class="block bg-white rounded-2xl shadow-sm border border-[#e9e9eb] overflow-hidden hover:shadow-md transition-shadow order-card">
          <div class="p-5">
            <!-- Top Row: Status & Date -->
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full order-status-dot <%= statusDot %>"></span>
                <span class="text-xs font-bold order-status-badge <%= statusColor %> px-2 py-0.5 rounded-full"><%= order.status %></span>
              </div>
              <span class="text-xs text-[#7e808c]"><%= dateStr %> at <%= timeStr %></span>
            </div>
            
            <!-- Order ID & Items -->
            <div class="mb-3">
              <p class="text-sm font-bold text-[#282c3f] mb-1">Order #<%= order.id %></p>
              <p class="text-xs text-[#7e808c] line-clamp-2">
                <%= order.items.map(i => (i.menuItem ? i.menuItem.name : 'Item') + ' x' + i.quantity).join(', ') %>
              </p>
            </div>
            
            <!-- Bottom Row: Price & Action -->
            <div class="flex items-center justify-between pt-3 border-t border-[#e9e9eb]">
              <div>
                <span class="text-lg font-bold text-[#282c3f]">&#8377;<%= order.totalAmount.toFixed(2) %></span>
                <span class="text-xs text-[#7e808c] ml-2">Paid via Stripe</span>
              </div>
              <div class="flex items-center gap-2">
                <% if (hasFeedback) { %>
                  <span class="text-xs text-green-600 font-semibold flex items-center gap-1">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                    Reviewed
                  </span>
                <% } %>
                <span class="text-orange-500 font-semibold text-xs">View Details &rarr;</span>
              </div>
            </div>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>

</div>

<script>
(function() {
  var statusColors = {
    'Pending': { bg: 'bg-yellow-50', text: 'text-yellow-700', dot: 'bg-yellow-400' },
    'Preparing': { bg: 'bg-blue-50', text: 'text-blue-700', dot: 'bg-blue-400' },
    'Ready': { bg: 'bg-indigo-50', text: 'text-indigo-700', dot: 'bg-indigo-400' },
    'Delivered': { bg: 'bg-green-50', text: 'text-green-700', dot: 'bg-green-400' },
    'Cancelled': { bg: 'bg-red-50', text: 'text-red-700', dot: 'bg-red-400' }
  };

  function showNotification(msg) {
    var n = document.createElement('div');
    n.className = 'fixed top-4 right-4 z-[9999] bg-gray-900 text-white px-4 py-3 rounded-lg shadow-lg text-sm font-medium';
    n.style.transition = 'opacity 0.3s';
    n.textContent = msg;
    document.body.appendChild(n);
    setTimeout(function() { n.style.opacity = '0'; setTimeout(function() { n.remove(); }, 300); }, 3000);
  }

  function updateOrderCard(orderId, status) {
    var card = document.querySelector('.order-card[data-order-id="' + orderId + '"]');
    if (!card) {
      showNotification('Order #' + orderId + ' is now ' + status);
      return;
    }
    var colors = statusColors[status] || statusColors['Pending'];
    var badge = card.querySelector('.order-status-badge');
    var dot = card.querySelector('.order-status-dot');
    if (badge) {
      badge.textContent = status;
      badge.className = 'text-xs font-bold px-2 py-0.5 rounded-full order-status-badge ' + colors.bg + ' ' + colors.text;
    }
    if (dot) {
      dot.className = 'w-2 h-2 rounded-full order-status-dot ' + colors.dot;
    }
    showNotification('Order #' + orderId + ' is now ' + status);
  }

  // Response Partialing: build an order card from lightweight JSON
  function buildOrderCard(order) {
    var colors = statusColors[order.status] || statusColors['Pending'];
    var d = new Date(order.createdAt);
    var dateStr = d.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
    var timeStr = d.toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' });
    var reviewBadge = order.hasFeedback
      ? '<span class="text-xs text-green-600 font-semibold flex items-center gap-1"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>Reviewed</span>'
      : '';
    var payLabel = 'Paid via Stripe';

    var html = '<a href="/orders/' + order.id + '" data-order-id="' + order.id + '" class="block bg-white rounded-2xl shadow-sm border border-[#e9e9eb] overflow-hidden hover:shadow-md transition-shadow order-card">'
      + '<div class="p-5">'
      + '<div class="flex items-center justify-between mb-4">'
      + '<div class="flex items-center gap-2">'
      + '<span class="w-2 h-2 rounded-full order-status-dot ' + colors.dot + '"></span>'
      + '<span class="text-xs font-bold order-status-badge ' + colors.bg + ' ' + colors.text + ' px-2 py-0.5 rounded-full">' + order.status + '</span>'
      + '</div>'
      + '<span class="text-xs text-[#7e808c]">' + dateStr + ' at ' + timeStr + '</span>'
      + '</div>'
      + '<div class="mb-3">'
      + '<p class="text-sm font-bold text-[#282c3f] mb-1">Order #' + order.id + '</p>'
      + '<p class="text-xs text-[#7e808c] line-clamp-2">' + order.itemsSummary + '</p>'
      + '</div>'
      + '<div class="flex items-center justify-between pt-3 border-t border-[#e9e9eb]">'
      + '<div><span class="text-lg font-bold text-[#282c3f]">&#8377;' + order.totalAmount.toFixed(2) + '</span>'
      + '<span class="text-xs text-[#7e808c] ml-2">' + payLabel + '</span></div>'
      + '<div class="flex items-center gap-2">' + reviewBadge
      + '<span class="text-orange-500 font-semibold text-xs">View Details &rarr;</span>'
      + '</div></div></div></a>';

    var tmp = document.createElement('div');
    tmp.innerHTML = html;
    return tmp.firstChild;
  }

  // Fetch partial JSON and prepend new order card
  async function handleNewOrder(data) {
    try {
      var res = await fetch('/orders/api/list', { headers: { 'Accept': 'application/json' } });
      if (!res.ok) return;
      var orders = await res.json();
      var newOrder = orders.find(function(o) { return String(o.id) === String(data.orderId); });
      if (!newOrder) return;

      // Remove empty state if present
      var emptyState = document.querySelector('.bg-white.rounded-2xl.shadow-sm.border .w-24');
      if (emptyState) {
        var emptyCard = emptyState.closest('.bg-white.rounded-2xl');
        if (emptyCard) {
          // Replace with a list container
          var list = document.createElement('div');
          list.className = 'space-y-4';
          list.id = 'orders-list';
          emptyCard.parentNode.replaceChild(list, emptyCard);
        }
      }

      var list = document.getElementById('orders-list') || document.querySelector('.space-y-4');
      if (list) {
        var existing = list.querySelector('[data-order-id="' + data.orderId + '"]');
        if (!existing) {
          var card = buildOrderCard(newOrder);
          list.insertBefore(card, list.firstChild);
        }
      }
      showNotification('New order placed! #' + data.orderId);
    } catch (e) {
      showNotification('New order placed! #' + data.orderId);
    }
  }

  function init() {
    if (!window.RestoRealtime) { setTimeout(init, 500); return; }
    window.RestoRealtime.on('order:status', function(data) { updateOrderCard(data.orderId, data.status); });
    window.RestoRealtime.on('order:cancel', function(data) { updateOrderCard(data.orderId, 'Cancelled'); });
    window.RestoRealtime.on('order:new', function(data) { handleNewOrder(data); });
  }
  init();
})();
</script>

<%- include('../partials/footer') %>
