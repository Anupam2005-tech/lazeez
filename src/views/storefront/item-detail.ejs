<%- include('../partials/header') %>

<div class="w-full sm:w-[90%] lg:w-[80%] mx-auto px-4 sm:px-6 pt-4 sm:pt-6 pb-20">
  
  <!-- Standard Back Button -->
  <a href="/" class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-white shadow-sm border border-[#e9e9eb] text-[#686b78] hover:text-[#fc8019] mb-6 transition-all active:scale-95 group">
    <svg class="w-5 h-5 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
    </svg>
  </a>

  <!-- Product Layout -->
  <div class="flex flex-col sm:flex-row gap-5 sm:gap-8">
    
    <!-- Image -->
    <div class="w-full sm:w-[45%] shrink-0">
      <div class="relative w-full aspect-[4/3] bg-gray-100 rounded-2xl overflow-hidden">
        <% if (item.image) { %>
          <img src="<%= item.image %>" class="w-full h-full object-cover" alt="<%= item.name %>">
        <% } else { %>
          <div class="w-full h-full bg-gradient-to-br from-orange-100 to-orange-200 flex items-center justify-center">
            <svg class="w-16 h-16 text-orange-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
        <% } %>

        <% if (item.isBestSeller) { %>
          <span class="absolute top-3 left-3 text-[10px] sm:text-[11px] font-bold text-orange-700 bg-orange-50 border border-orange-200 px-2 sm:px-3 py-1 rounded-full">
            BEST SELLER
          </span>
        <% } %>
      </div>
    </div>

    <!-- Details -->
    <div class="flex-1 min-w-0">
      <div class="bg-white rounded-2xl border border-[#e9e9eb] p-4 sm:p-6">
        
        <!-- Title row -->
        <div class="flex items-start justify-between gap-3 mb-2">
          <div class="flex-1 min-w-0">
            <% 
              const liquidKeywords = ['beverage', 'tea', 'coffee', 'juice', 'shake', 'drink', 'liquid'];
              const isLiquid = liquidKeywords.some(k => (item.categoryName || '').toLowerCase().includes(k));
            %>
            <h1 class="text-xl sm:text-2xl font-bold text-[#3d4152] leading-tight"><%= item.name %></h1>
            <p class="text-xs sm:text-sm text-[#7e808c] mt-1"><%= item.categoryName || 'Uncategorized' %></p>
            <div class="font-medium text-[#3d4152] text-lg sm:text-xl mt-3 mb-1">₹<%= Number(item.price).toFixed(2) %></div>
          </div>
          <div class="shrink-0">
            <% if (!isLiquid) { %>
              <% if (item.isVeg) { %>
                <span class="w-5 h-5 sm:w-6 sm:h-6 border-2 border-green-600 rounded-sm flex items-center justify-center">
                  <span class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-green-600"></span>
                </span>
              <% } else { %>
                <span class="w-5 h-5 sm:w-6 sm:h-6 border-2 border-red-600 rounded-sm flex items-center justify-center">
                  <span class="w-2.5 h-2.5 sm:w-3 sm:h-3 bg-red-600" style="clip-path: polygon(50% 0%, 0% 100%, 100% 100%);"></span>
                </span>
              <% } %>
            <% } %>
          </div>
        </div>

        <!-- Rating & Price -->
        <div class="flex items-center gap-2 sm:gap-3 mb-3 sm:mb-4 text-sm flex-wrap">
          <div class="flex items-center gap-1 bg-green-600 text-white text-[11px] sm:text-xs font-bold px-2 py-1 rounded-lg">
            <svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            <span><%= avgRating > 0 ? avgRating : '—' %></span>
          </div>
          <% if (totalReviews > 0) { %>
            <span class="text-xs sm:text-sm text-[#7e808c]"><%= totalReviews %> <%= totalReviews === 1 ? 'rating' : 'ratings' %></span>
          <% } %>
        </div>

        <!-- Divider -->
        <div class="border-t border-[#e9e9eb] mb-3 sm:mb-4"></div>

        <!-- Description -->
        <div class="mb-3 sm:mb-4">
          <h3 class="text-xs sm:text-sm font-semibold text-[#3d4152] mb-1">Description</h3>
          <p class="text-xs sm:text-sm text-[#686b78] leading-relaxed"><%= item.description || 'A delicious dish prepared with fresh ingredients and authentic spices.' %></p>
        </div>

        <!-- What you get -->
        <div class="mb-3 sm:mb-4">
          <h3 class="text-xs sm:text-sm font-semibold text-[#3d4152] mb-2">What you get</h3>
          <div class="flex flex-wrap gap-x-4 gap-y-1">
            <span class="flex items-center gap-1.5 text-xs sm:text-sm text-[#686b78]">
              <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-green-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <%= item.name %>
            </span>
            <span class="flex items-center gap-1.5 text-xs sm:text-sm text-[#686b78]">
              <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-green-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <%= isLiquid ? 'Refreshing Beverage' : (item.isVeg ? 'Pure Vegetarian' : 'Non-Vegetarian') %>
            </span>
            <span class="flex items-center gap-1.5 text-xs sm:text-sm text-[#686b78]">
              <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-green-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              Serves 1
            </span>
          </div>
        </div>

        <!-- Ingredients -->
        <div class="mb-3 sm:mb-4">
          <h3 class="text-xs sm:text-sm font-semibold text-[#3d4152] mb-2">Ingredients</h3>
          <div class="flex flex-wrap gap-1.5 sm:gap-2">
            <span class="px-2.5 sm:px-3 py-1 bg-gray-100 text-[10px] sm:text-xs font-medium text-[#535665] rounded-full">Fresh Herbs</span>
            <span class="px-2.5 sm:px-3 py-1 bg-gray-100 text-[10px] sm:text-xs font-medium text-[#535665] rounded-full">Premium Spices</span>
            <span class="px-2.5 sm:px-3 py-1 bg-gray-100 text-[10px] sm:text-xs font-medium text-[#535665] rounded-full">Quality Oil</span>
            <span class="px-2.5 sm:px-3 py-1 bg-gray-100 text-[10px] sm:text-xs font-medium text-[#535665] rounded-full">Fresh Produce</span>
          </div>
        </div>

        <!-- Allergen info -->
        <div class="bg-amber-50 border border-amber-200 rounded-lg p-2.5 sm:p-3 mb-4 sm:mb-5">
          <div class="flex items-center gap-2">
            <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-amber-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
            <p class="text-[11px] sm:text-xs text-amber-800">May contain traces of nuts, dairy, and gluten.</p>
          </div>
        </div>

         <!-- Add to Cart -->
         <div class="flex items-center justify-between gap-3 sm:gap-4">
           <div class="w-12"></div>
           <% if (item.available) { %>
            <div data-menu-item-id="<%= item.id %>" data-full-width class="flex-1">
              <button type="button" onclick="RestoCart.add('<%= item.id %>')" class="btn-add w-full py-2.5 sm:py-3 px-4 sm:px-6 rounded-xl text-sm">ADD TO CART</button>
            </div>
          <% } else { %>
            <button disabled class="flex-1 bg-gray-200 text-gray-400 font-bold py-2.5 sm:py-3 px-4 sm:px-6 rounded-xl text-sm cursor-not-allowed">Unavailable</button>
          <% } %>
        </div>
      </div>
    </div>

  </div>

  <!-- Reviews Section -->
  <div class="mt-5 sm:mt-6 bg-white rounded-2xl border border-[#e9e9eb] p-4 sm:p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-base sm:text-lg font-bold text-[#282c3f]">Reviews</h2>
      <% if (totalReviews > 0) { %>
        <div class="flex items-center gap-2">
          <div class="flex items-center gap-1 bg-green-600 text-white text-[11px] sm:text-xs font-bold px-2 py-1 rounded-lg">
            <svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            <span><%= avgRating %></span>
          </div>
          <span class="text-xs sm:text-sm text-[#7e808c]"><%= totalReviews %> <%= totalReviews === 1 ? 'review' : 'reviews' %></span>
        </div>
      <% } %>
    </div>

    <% if (totalReviews === 0) { %>
      <p class="text-sm text-[#93959f] text-center py-6">No reviews yet for this item.</p>
    <% } else { %>
      <div class="space-y-4">
        <% reviews.forEach(function(review) { %>
          <div class="border-b border-[#e9e9eb] last:border-b-0 pb-4 last:pb-0">
            <div class="flex items-center justify-between mb-1.5">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-orange-100 flex items-center justify-center text-orange-600 text-xs font-bold shrink-0">
                  <%= review.userName.charAt(0).toUpperCase() %>
                </div>
                <span class="text-sm font-semibold text-[#282c3f]"><%= review.userName %></span>
              </div>
              <div class="flex items-center gap-0.5">
                <% for (let i = 1; i <= 5; i++) { %>
                  <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 <%= i <= review.foodRating ? 'text-yellow-400' : 'text-gray-200' %>" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                <% } %>
              </div>
            </div>
            <% if (review.comment) { %>
              <p class="text-sm text-[#686b78] ml-10 mb-1"><%= review.comment %></p>
            <% } %>
            <p class="text-[11px] sm:text-xs text-[#93959f] ml-10"><%= new Date(review.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></p>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <!-- Item ID badge -->
  <div class="mt-3 text-right">
    <span class="text-[10px] text-[#c0c2c9]">Item #<%= item.uid %></span>
  </div>

</div>

<%- include('../partials/footer') %>
