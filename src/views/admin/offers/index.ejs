<div class="flex justify-between items-center mb-6">
  <h2 class="text-xl font-bold text-gray-800">Manage Offers</h2>
  <a href="/admin/offers/add" class="bg-orange-500 hover:bg-orange-600 text-white px-4 py-2 rounded-lg font-semibold text-sm transition-colors">
    + Add Offer
  </a>
</div>

<% if (offers.length === 0) { %>
  <div class="py-12 text-center text-gray-500 font-medium">No offers yet. Create your first offer!</div>
<% } else { %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <% offers.forEach(offer => { %>
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm">
        <% if (offer.image) { %>
          <div class="h-40 bg-gray-100 overflow-hidden">
            <img src="<%= offer.image %>" class="w-full h-full object-cover" alt="<%= offer.name %>">
          </div>
        <% } else { %>
          <div class="h-40 bg-gradient-to-br from-orange-100 to-orange-200 flex items-center justify-center">
            <svg class="w-12 h-12 text-orange-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/>
            </svg>
          </div>
        <% } %>
        <div class="p-4">
          <div class="flex items-center justify-between mb-1">
            <h3 class="font-bold text-gray-800 truncate"><%= offer.name %></h3>
            <span class="text-[10px] font-bold px-2 py-0.5 rounded-full <%= offer.active ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500' %>">
              <%= offer.active ? 'ACTIVE' : 'INACTIVE' %>
            </span>
          </div>
          <p class="text-sm text-gray-500 line-clamp-2 mb-1"><%= offer.description || 'No description' %></p>
          <% if (offer.dishName) { %>
            <p class="text-xs text-orange-600 font-semibold mb-2">Filter: <%= offer.dishName %></p>
          <% } else { %>
            <p class="text-xs text-gray-400 mb-2">No dish filter</p>
          <% } %>
          <div class="flex gap-2">
            <a href="/admin/offers/edit/<%= offer.id %>" class="flex-1 text-center bg-gray-100 hover:bg-gray-200 text-gray-700 px-3 py-1.5 rounded-lg text-xs font-semibold transition-colors">Edit</a>
            <form action="/admin/offers/delete/<%= offer.id %>" method="POST" class="flex-1" onsubmit="return RestoConfirm.handleDelete(this, event, 'Delete this offer? This cannot be undone.')">
              <button type="submit" class="w-full bg-red-50 hover:bg-red-100 text-red-600 px-3 py-1.5 rounded-lg text-xs font-semibold transition-colors">Delete</button>
            </form>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>
