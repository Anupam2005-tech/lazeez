<div class="flex justify-between items-center mb-6">
  <h2 class="text-xl font-bold text-gray-800">Manage Categories</h2>
  <a href="/admin/categories/add" class="bg-orange-500 hover:bg-orange-600 text-white px-4 py-2 rounded-lg font-semibold text-sm transition-colors">
    + Add Category
  </a>
</div>

<% if (categories.length === 0) { %>
  <div class="py-12 text-center text-gray-500 font-medium">No categories yet. Create your first category!</div>
<% } else { %>
  <div class="bg-white shadow overflow-x-auto sm:rounded-lg border">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ID</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Image</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Menu Items</th>
          <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% categories.forEach(cat => { %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-gray-500">#<%= cat.id %></td>
            <td class="px-6 py-4 whitespace-nowrap">
              <% if (cat.image) { %>
                <div class="w-12 h-12 rounded-lg overflow-hidden bg-gray-100">
                  <img src="<%= cat.image %>" class="w-full h-full object-cover" alt="<%= cat.name %>">
                </div>
              <% } else { %>
                <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-indigo-100 to-indigo-200 flex items-center justify-center">
                  <svg class="w-6 h-6 text-indigo-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                  </svg>
                </div>
              <% } %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="text-sm font-bold text-gray-900"><%= cat.name %></span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="px-2.5 py-1 text-xs font-bold rounded-full bg-blue-100 text-blue-700">
                <%= cat._count.menuItems %> items
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right">
              <div class="flex items-center justify-end gap-2">
                <a href="/admin/categories/edit/<%= cat.id %>" class="bg-gray-100 hover:bg-gray-200 text-gray-700 px-3 py-1.5 rounded-lg text-xs font-semibold transition-colors">Edit</a>
                <form action="/admin/categories/delete/<%= cat.id %>" method="POST" onsubmit="return RestoConfirm.handleDelete(this, event, 'Delete category &quot;<%= cat.name %>&quot;? This cannot be undone.')">
                  <button type="submit" class="bg-red-50 hover:bg-red-100 text-red-600 px-3 py-1.5 rounded-lg text-xs font-semibold transition-colors">Delete</button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>
