<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login - Lazeez</title>
  <meta name="robots" content="noindex, nofollow">
  <meta name="theme-color" content="#1f2937">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://www.gstatic.com/firebasejs/10.9.0/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.9.0/firebase-auth-compat.js"></script>
  <style>.grecaptcha-badge { display: none !important; }</style>
  <% if (typeof recaptchaSiteKey !== 'undefined' && recaptchaSiteKey) { %>
  <script src="https://www.google.com/recaptcha/api.js?render=<%= recaptchaSiteKey %>" async defer></script>
  <% } %>
  <script>
    window.FIREBASE_CONFIG = {
      apiKey: "<%= firebaseApiKey %>",
      authDomain: "<%= firebaseAuthDomain %>",
      projectId: "<%= firebaseProjectId %>",
      storageBucket: "<%= firebaseStorageBucket %>",
      messagingSenderId: "<%= firebaseMessagingSenderId %>",
      appId: "<%= firebaseAppId %>"
    };
  </script>
  <script src="/js/firebase-client.js"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen">

  <div class="max-w-md w-full bg-white p-8 border rounded-lg shadow-lg">
    <div class="text-center mb-8">
      <h2 class="text-3xl font-extrabold text-gray-900">Admin Portal</h2>
      <p class="text-sm text-gray-600 mt-2">Sign in to manage the system</p>
    </div>

    <div id="error-msg" class="hidden mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-600"></div>

    <form id="adminLoginForm" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700">Email</label>
        <input type="email" id="email" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-red-500 focus:ring-red-500 sm:text-sm px-3 py-2 border">
      </div>
      
      <div>
        <label class="block text-sm font-medium text-gray-700">Password</label>
        <input type="password" id="password" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-red-500 focus:ring-red-500 sm:text-sm px-3 py-2 border">
      </div>

      <button type="submit" id="loginBtn" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-red-600 hover:bg-red-700">
        Admin Sign In
      </button>
    </form>

    <div class="mt-6">
      <div class="relative">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-gray-300"></div>
        </div>
        <div class="relative flex justify-center text-sm">
          <span class="px-2 bg-white text-gray-500">Or admin login with</span>
        </div>
      </div>

      <div class="mt-6">
        <button onclick="tryGoogleLogin()" class="w-full inline-flex justify-center py-2 px-4 border border-gray-300 rounded-md shadow-sm bg-white text-sm font-medium text-gray-700 hover:bg-gray-50">
          Google
        </button>
      </div>
    </div>

    <div class="mt-4 p-3 bg-blue-50 rounded-lg">
      <p class="text-xs text-blue-600 text-center">Demo: <strong>admin@lazeez.com</strong> / <strong>admin123</strong></p>
    </div>
  </div>

  <script>
    function showError(msg) {
      var el = document.getElementById('error-msg');
      el.textContent = msg;
      el.classList.remove('hidden');
    }
    function hideError() {
      document.getElementById('error-msg').classList.add('hidden');
    }
    
    // Catch messages launched by firebase-client.js
    window.RestoAlert = {
      show: function(msg) { showError(msg); }
    };

    function tryGoogleLogin() {
      if (window.RestoAuth && window.RestoAuth.handleGoogleLogin) {
        RestoAuth.handleGoogleLogin('/admin/verify-token');
      } else {
        showError('Google login is not available. Use email/password login.');
      }
    }

    document.getElementById('adminLoginForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      hideError();
      var btn = document.getElementById('loginBtn');
      var email = document.getElementById('email').value;
      var password = document.getElementById('password').value;
      btn.disabled = true;
      btn.textContent = 'Signing in...';

      // Try Firebase auth first, fall back to local auth
      try {
        if (window.RestoAuth && window.RestoAuth.handleEmailLogin) {
          var recaptchaToken = '';
          if (window.grecaptcha && window.RECAPTCHA_SITE_KEY) {
            try { recaptchaToken = await grecaptcha.execute(window.RECAPTCHA_SITE_KEY, {action: 'admin_login'}); } catch(ex) {}
          }
          var auth = firebase.auth();
          var cred = await auth.signInWithEmailAndPassword(email, password);
          var idToken = await cred.user.getIdToken();
          var res = await fetch('/admin/verify-token', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ idToken: idToken, recaptchaToken: recaptchaToken })
          });
          var data = await res.json();
          if (data.success) {
            window.location.href = '/admin/dashboard';
            return;
          }
          showError(data.error || 'Login failed');
        } else {
          throw new Error('Firebase not available');
        }
      } catch (firebaseErr) {
        // Firebase failed, try local auth
        try {
          var res = await fetch('/admin/local-login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: email, password: password })
          });
          var data = await res.json();
          if (data.success) {
            window.location.href = '/admin/dashboard';
            return;
          }
          showError(data.error || 'Login failed');
        } catch (localErr) {
          showError('Login failed. Please check your credentials.');
        }
      }
      btn.disabled = false;
      btn.textContent = 'Admin Sign In';
    });
  </script>
</body>
</html>
