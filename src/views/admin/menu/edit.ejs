<div class="max-w-3xl mx-auto">
  <div class="mb-6 flex items-center justify-between">
    <h2 class="text-2xl font-bold text-[#3d4152]">Edit Dish: <%= item.name %></h2>
    <a href="/admin/menu" class="text-orange-600 hover:text-orange-700 font-medium text-sm">&larr; Back to Menu</a>
  </div>

  <div class="bg-white p-6 shadow-sm rounded-2xl border border-[#e9e9eb]">
    <form action="/admin/menu/edit/<%= item.uid %>" method="POST" enctype="multipart/form-data" class="space-y-6">
      
      <div>
        <label class="block text-sm font-bold text-[#3d4152]">Dish Name</label>
        <input type="text" name="name" value="<%= item.name %>" required class="mt-1 block w-full border border-gray-300 rounded-xl py-3 px-4 focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500 text-sm">
      </div>

      <div>
        <label class="block text-sm font-bold text-[#3d4152]">Category</label>
        <select name="categoryId" required class="mt-1 block w-full bg-white border border-gray-300 rounded-xl py-3 px-4 focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500 text-sm">
          <% categories.forEach(cat => { %>
            <option value="<%= cat.id %>" <%= item.categoryId === cat.id ? 'selected' : '' %>><%= cat.name %></option>
          <% }) %>
        </select>
      </div>

      <div>
        <label class="block text-sm font-bold text-[#3d4152]">Price (₹)</label>
        <input type="number" step="0.01" name="price" value="<%= item.price %>" required class="mt-1 block w-full border border-gray-300 rounded-xl py-3 px-4 focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500 text-sm">
      </div>

      <div>
        <label class="block text-sm font-bold text-[#3d4152]">Description</label>
        <textarea name="description" rows="3" class="mt-1 block w-full border border-gray-300 rounded-xl py-3 px-4 focus:outline-none focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500 text-sm"><%= item.description %></textarea>
      </div>

      <div>
        <label class="block text-sm font-bold text-[#3d4152] mb-2">Dish Image</label>
        
        <div class="mb-3 <%= item.image ? '' : 'hidden' %>" id="preview-container">
          <p class="text-sm text-gray-500 mb-1" id="preview-text">Current Image:</p>
          <img id="image-preview" src="<%= item.image || '#' %>" class="h-32 w-32 object-cover rounded-xl border border-gray-200">
        </div>
        
        <div class="mt-1 flex items-center">
          <input type="file" id="image-upload" name="image" accept="image/*" class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-bold file:bg-orange-50 file:text-orange-600 hover:file:bg-orange-100 transition-colors">
        </div>
        <p class="mt-2 text-[11px] text-gray-400">Any image format up to 10MB. Auto-compressed to AVIF.</p>
      </div>

      <div class="flex items-center">
        <input id="available" name="available" type="checkbox" <%= item.available ? 'checked' : '' %> class="h-4 w-4 text-orange-600 focus:ring-orange-500 border-gray-300 rounded">
        <label for="available" class="ml-2 block text-sm text-[#3d4152] font-medium">
          Currently Available
        </label>
      </div>

      <div class="flex items-center" id="veg-toggle-container">
        <input id="isVeg" name="isVeg" type="checkbox" <%= item.isVeg ? 'checked' : '' %> class="h-4 w-4 text-orange-600 focus:ring-orange-500 border-gray-300 rounded">
        <label for="isVeg" class="ml-2 block text-sm text-[#3d4152] font-medium">
          Veg item (uncheck for Non-Veg)
        </label>
      </div>

      <div class="flex items-center">
        <input id="isBestSeller" name="isBestSeller" type="checkbox" <%= item.isBestSeller ? 'checked' : '' %> class="h-4 w-4 text-orange-600 focus:ring-orange-500 border-gray-300 rounded">
        <label for="isBestSeller" class="ml-2 block text-sm text-[#3d4152] font-medium">
          Best Seller
        </label>
      </div>

      <div class="pt-5 border-t border-gray-100">
        <div class="flex justify-end gap-3">
          <a href="/admin/menu" class="bg-white py-2.5 px-6 border border-gray-200 rounded-xl text-sm font-bold text-[#3d4152] hover:bg-gray-50 transition-colors">Cancel</a>
          <button type="submit" class="bg-orange-600 hover:bg-orange-700 text-white font-bold py-2.5 px-6 rounded-xl text-sm transition-colors shadow-lg shadow-orange-200">Update Item</button>
        </div>
      </div>
    </form>
  </div>
</div>

<script id="categories-data" type="application/json"><%- JSON.stringify(categories) %></script>
<script>
  document.getElementById('image-upload').addEventListener('change', function(event) {
    const file = event.target.files[0];
    const previewContainer = document.getElementById('preview-container');
    const imagePreview = document.getElementById('image-preview');
    const previewText = document.getElementById('preview-text');

    if (file) {
      if (file.size > 10 * 1024 * 1024) {
        alert('File size exceeds 10MB limit.');
        event.target.value = '';
        return;
      }
      imagePreview.src = URL.createObjectURL(file);
      previewText.innerText = 'New Image Preview:';
      previewContainer.classList.remove('hidden');
    }
  });

  const categories = JSON.parse(document.getElementById('categories-data').textContent);
  const categorySelect = document.querySelector('select[name="categoryId"]');
  const vegToggleContainer = document.getElementById('veg-toggle-container');
  const isVegCheckbox = document.getElementById('isVeg');
  const liquidKeywords = ['beverage', 'tea', 'coffee', 'juice', 'shake', 'drink', 'liquid'];

  function updateVegToggle() {
    const selectedId = categorySelect.value;
    const category = categories.find(c => c.id === selectedId);
    if (category) {
      const isLiquid = liquidKeywords.some(k => category.name.toLowerCase().includes(k));
      if (isLiquid) {
        vegToggleContainer.classList.add('hidden');
        isVegCheckbox.checked = true; // Default to veg for liquids
      } else {
        vegToggleContainer.classList.remove('hidden');
      }
    }
  }

  categorySelect.addEventListener('change', updateVegToggle);
  updateVegToggle();
</script>
