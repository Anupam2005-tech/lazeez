<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' - Lazeez' : 'Lazeez' %></title>
  <link rel="icon" type="image/svg+xml" href="/img/logo.svg">
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Firebase SDK -->
  <script src="/js/firebase-app-compat.js"></script>
  <script src="/js/firebase-auth-compat.js"></script>
  <!-- Google reCAPTCHA v3 -->
  <script>
    window.RECAPTCHA_SITE_KEY = '<%= recaptchaSiteKey %>';
  </script>
  <% if (typeof recaptchaSiteKey !== 'undefined' && recaptchaSiteKey) { %>
  <script src="https://www.google.com/recaptcha/api.js?render=<%= recaptchaSiteKey %>" async defer></script>
  <% } %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
  <style>
    :root { font-family: 'Plus Jakarta Sans', sans-serif; }
    /* Custom styles */
    .glassmorphism {
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.5);
    }
  </style>
  <script>
    window.FIREBASE_CONFIG = {
      apiKey: "<%= firebaseApiKey %>",
      authDomain: "<%= firebaseAuthDomain %>",
      projectId: "<%= firebaseProjectId %>",
      storageBucket: "<%= firebaseStorageBucket %>",
      messagingSenderId: "<%= firebaseMessagingSenderId %>",
      appId: "<%= firebaseAppId %>"
    };
  </script>
  <script src="/js/firebase-client.js"></script>
  <!-- Vercel Web Analytics -->
  <script defer src="https://cdn.vercel-insights.com/v1/script.js"></script>
</head>
<body class="bg-gray-50 text-gray-900 font-sans antialiased min-h-screen flex flex-col pt-16">
  
  <%- include('../partials/navbar') %>

  <main class="flex-grow">
    <%- body %>
  </main>

  <%- include('../partials/footer') %>

</body>
</html>
