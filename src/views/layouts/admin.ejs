<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' - Admin Panel' : 'Lazeez Admin Panel' %></title>
  <meta name="robots" content="noindex, nofollow">
  <meta name="theme-color" content="#1f2937">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Firebase SDK -->
  <script src="https://www.gstatic.com/firebasejs/10.9.0/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.9.0/firebase-auth-compat.js"></script>
  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <!-- Google reCAPTCHA v3 -->
  <script>
    window.RECAPTCHA_SITE_KEY = '<%= recaptchaSiteKey %>';
  </script>
  <% if (typeof recaptchaSiteKey !== 'undefined' && recaptchaSiteKey) { %>
  <script src="https://www.google.com/recaptcha/api.js?render=<%= recaptchaSiteKey %>" async defer></script>
  <% } %>
  <style>
    /* Custom admin styles */
    [x-cloak] { display: none !important; }
  </style>
  <!-- Alpine.js for lightweight interactions -->
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <script>
    window.FIREBASE_CONFIG = {
      apiKey: "<%= firebaseApiKey %>",
      authDomain: "<%= firebaseAuthDomain %>",
      projectId: "<%= firebaseProjectId %>",
      storageBucket: "<%= firebaseStorageBucket %>",
      messagingSenderId: "<%= firebaseMessagingSenderId %>",
      appId: "<%= firebaseAppId %>"
    };
  </script>
  <script src="/js/firebase-client.js"></script>
</head>
<body class="bg-gray-100 text-gray-800 font-sans antialiased flex min-h-screen" x-data="{ sidebarOpen: false }">
  
  <!-- Mobile sidebar backdrop -->
  <div x-show="sidebarOpen" 
       class="fixed inset-0 z-10 bg-gray-900 bg-opacity-50 transition-opacity md:hidden"
       @click="sidebarOpen = false"
       x-transition:enter="transition-opacity ease-linear duration-300"
       x-transition:enter-start="opacity-0"
       x-transition:enter-end="opacity-100"
       x-transition:leave="transition-opacity ease-linear duration-300"
       x-transition:leave-start="opacity-100"
       x-transition:leave-end="opacity-0"
       x-cloak>
  </div>

  <%- include('../partials/admin-sidebar') %>

   <div class="flex-1 flex flex-col min-h-screen">
    <header class="bg-white shadow-sm border-b px-6 py-4 flex items-center z-10 relative">
      <div class="flex items-center gap-4">
        <button @click="sidebarOpen = true" class="md:hidden text-gray-500 hover:text-gray-700 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-orange-500">
          <span class="sr-only">Open sidebar</span>
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
        <h1 class="text-2xl font-bold text-gray-800"><%= typeof title !== 'undefined' ? title : 'Dashboard' %></h1>
      </div>
    </header>

    <main class="flex-1 overflow-x-hidden overflow-y-auto bg-gray-50 p-6">
      <%- body %>
    </main>
  </div>

  <script src="/js/admin.js"></script>
  <script src="/js/realtime.js"></script>
</body>
</html>
